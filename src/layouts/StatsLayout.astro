    .stats-page .share-icons { margin-left: 0; margin-top: 8px; flex-basis: 100%; }
    .stats-page .article-footer-inner { flex-direction: column; gap: 16px; align-items: flex-start; }
    .stat-grid { grid-template-columns: 1fr; }
    .stat-card .stat-number { font-size: 2.25rem; }
  }
</style>

<script>
  // ========== STAT CARD TRANSFORMATION ==========
  // Transforms bold paragraphs in the stats body into visual stat cards in a grid layout.
  // Also transforms "What This Means" H3 sections into commentary blocks.

  const statsBody = document.getElementById('stats-body');
  if (statsBody) {
    const h2s = statsBody.querySelectorAll('h2');

    h2s.forEach((h2) => {
      // Collect stat paragraphs (bold-only <p><strong>...</strong></p>) between this H2 and the next section break
      let sibling = h2.nextElementSibling;
      const statParagraphs: Element[] = [];
      const commentaryElements: Element[] = [];
      let inCommentary = false;

      while (sibling && sibling.tagName !== 'H2' && sibling.tagName !== 'HR') {
        if (sibling.tagName === 'H3') {
          inCommentary = true;
          // Skip the H3 itself — we don't need to render "What This Means for GTM Leaders" as a heading
          sibling = sibling.nextElementSibling;
          continue;
        }

        if (inCommentary) {
          commentaryElements.push(sibling);
        } else if (sibling.tagName === 'P') {
          const strong = sibling.querySelector(':scope > strong:first-child');
          const text = (sibling as HTMLElement).textContent || '';
          if (strong && (text.includes('Source:') || text.match(/^\*?\*?[\d$]/))) {
            // Paragraph starts with bold and contains a source citation = a stat
            statParagraphs.push(sibling);
          }
        }

        sibling = sibling.nextElementSibling;
      }

      // Add count badge to H2
      if (statParagraphs.length > 0) {
        const badge = document.createElement('span');
        badge.className = 'stat-count-badge';
        badge.textContent = `${statParagraphs.length} stats`;
        h2.appendChild(badge);
      }

      // Build stat grid
      if (statParagraphs.length > 0) {
        const grid = document.createElement('div');
        grid.className = 'stat-grid';

        statParagraphs.forEach((p) => {
          const html = (p as HTMLElement).innerHTML;
          // Extract the bold stat text and everything after it
          const strongMatch = html.match(/<strong>([\s\S]*?)<\/strong>([\s\S]*)/);
          if (!strongMatch) return;

          // Combine bold text + trailing context into one string
          const fullText = strongMatch[1] + (strongMatch[2] || '');

          // Extract the big number — look for a leading stat like "73%", "60%", "$463 billion", "14.2%", "8x", "2.5x", etc.
          const numberMatch = fullText.match(/^([\$]?[\d,.]+(?:\.\d+)?(?:%|x|(?:\s+(?:billion|million|trillion|thousand)))?)/i);

          let bigNumber = '';
          let contextHtml = fullText;

          if (numberMatch) {
            bigNumber = numberMatch[1].trim();
            contextHtml = fullText.slice(numberMatch[0].length).trim();
            // Remove leading "of", "the", etc. that start with lowercase after the number
          }

          // Extract source — look for (Source: ...) at the end
          const sourceMatch = contextHtml.match(/\s*\(Source:\s*([\s\S]*?)\)\s*$/);
          let sourceName = '';
          let sourceDate = '';
          if (sourceMatch) {
            contextHtml = contextHtml.slice(0, sourceMatch.index).trim();
            const sourceText = sourceMatch[1].trim();
            // Try to extract date at end like ", 2026" or ", March 2026"
            const dateMatch = sourceText.match(/,?\s*((?:January|February|March|April|May|June|July|August|September|October|November|December)\s+)?\d{4}(?:\s*[-–]\s*\d{4})?\s*$/i);
            if (dateMatch) {
              sourceDate = dateMatch[0].replace(/^,?\s*/, '').trim();
              sourceName = sourceText.slice(0, dateMatch.index).trim();
              // Clean trailing comma or slash
              sourceName = sourceName.replace(/[,\/\s]+$/, '').trim();
            } else {
              sourceName = sourceText;
            }
          }

          const card = document.createElement('div');
          card.className = 'stat-card';

          let cardHtml = '';
          if (bigNumber) {
            cardHtml += `<div class="stat-number">${bigNumber}</div>`;
          }
          cardHtml += `<div class="stat-context">${contextHtml}</div>`;
          if (sourceName || sourceDate) {
            cardHtml += '<div class="stat-source">';
            if (sourceName) {
              // Strip any remaining HTML link tags for the pill, keep text
              const plainSource = sourceName.replace(/<[^>]+>/g, '');
              cardHtml += `<span class="stat-source-pill">${plainSource}</span>`;
            }
            if (sourceDate) {
              cardHtml += `<span class="stat-source-date">${sourceDate}</span>`;
            }
            cardHtml += '</div>';
          }

          card.innerHTML = cardHtml;
          grid.appendChild(card);

          // Remove original paragraph from DOM
          p.remove();
        });

        // Insert grid after the H2
        h2.insertAdjacentElement('afterend', grid);
      }

      // Wrap commentary in a block
      if (commentaryElements.length > 0) {
        const block = document.createElement('div');
        block.className = 'commentary-block';
        // Insert before the first commentary element
        commentaryElements[0].parentNode?.insertBefore(block, commentaryElements[0]);
        commentaryElements.forEach((el) => block.appendChild(el));
      }
    });
  }

  // ========== SECTION TOC ==========
  const tocContainer = document.getElementById('section-toc-inner');
  const tocNav = document.getElementById('section-toc');
  if (tocContainer && statsBody) {
    const headings = statsBody.querySelectorAll('h2');
    const tocItems: { el: Element; pill: HTMLElement }[] = [];

    headings.forEach((h2, i) => {
      // Assign an ID for anchor links
      const id = h2.id || `section-${i}`;
      h2.id = id;

      const pill = document.createElement('a');
      pill.className = 'section-toc-pill';
      pill.href = `#${id}`;
      // Get text content without the badge
      const badge = h2.querySelector('.stat-count-badge');
      const textOnly = h2.textContent?.replace(badge?.textContent || '', '').trim() || '';
      // Shorten long section names
      const shortName = textOnly.length > 35 ? textOnly.slice(0, 32) + '...' : textOnly;
      pill.textContent = shortName;

      pill.addEventListener('click', (e) => {
        e.preventDefault();
        h2.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });

      tocContainer.appendChild(pill);
      tocItems.push({ el: h2, pill });
    });

    // Highlight active section on scroll
    if (tocItems.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const match = tocItems.find((item) => item.el === entry.target);
              if (match) {
                tocItems.forEach((item) => item.pill.classList.remove('active'));
                match.pill.classList.add('active');
                // Scroll pill into view
                match.pill.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
              }
            }
          });
        },
        { rootMargin: '-10% 0px -80% 0px', threshold: 0 }
      );

      tocItems.forEach((item) => observer.observe(item.el));
    }
  }

  // ========== READING TIME ==========
  const proseEl = document.querySelector('.stats-body');
  const readingTimeEl = document.getElementById('reading-time');
  if (proseEl && readingTimeEl) {
    const text = proseEl.textContent || '';
    const words = text.trim().split(/\s+/).length;
    const minutes = Math.max(1, Math.ceil(words / 250));
    readingTimeEl.textContent = `${minutes} min read`;
  }

  // ========== READING PROGRESS BAR ==========
  const progressFill = document.getElementById('progress-bar-fill');
  if (progressFill) {
    const statsPage = document.querySelector('.stats-page');
    if (statsPage) {
      window.addEventListener('scroll', () => {
        const rect = statsPage.getBoundingClientRect();
        const total = statsPage.scrollHeight - window.innerHeight;
        const scrolled = -rect.top;
        const pct = Math.min(100, Math.max(0, (scrolled / total) * 100));
        progressFill.style.width = `${pct}%`;
      }, { passive: true });
    }
  }

  // ========== COPY LINK ==========
  const copyBtn = document.getElementById('copy-link-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href).then(() => {
        copyBtn.title = 'Copied!';
        setTimeout(() => { copyBtn.title = 'Copy link'; }, 2000);
      });
    });
  }
</script>
