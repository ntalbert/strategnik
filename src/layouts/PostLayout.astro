<script>
  // Hero video transition effect
  const heroMedia = document.getElementById('hero-media');
  const heroVideo = document.getElementById('hero-video') as HTMLVideoElement;

  if (heroMedia && heroVideo) {
    setTimeout(() => {
      heroMedia.classList.add('video-active');
      heroVideo.play().catch(() => {});
    }, 1000);

    heroVideo.addEventListener('ended', () => {
      heroVideo.currentTime = 0;
      heroVideo.play().catch(() => {});
    });
  }

  // Reading time estimate
  const proseEl = document.querySelector('.article-body');
  const readingTimeEl = document.getElementById('reading-time');
  if (proseEl && readingTimeEl) {
    const text = proseEl.textContent || '';
    const words = text.trim().split(/\s+/).length;
    const minutes = Math.max(1, Math.ceil(words / 250));
    readingTimeEl.textContent = `${minutes} min read`;
  }

  // Reading progress bar
  const progressFill = document.getElementById('progress-bar-fill');
  if (progressFill) {
    const articlePage = document.querySelector('.article-page');
    if (articlePage) {
      window.addEventListener('scroll', () => {
        const rect = articlePage.getBoundingClientRect();
        const total = articlePage.scrollHeight - window.innerHeight;
        const scrolled = -rect.top;
        const pct = Math.min(100, Math.max(0, (scrolled / total) * 100));
        progressFill.style.width = `${pct}%`;
      }, { passive: true });
    }
  }

  // Copy link button
  const copyBtn = document.getElementById('copy-link-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href).then(() => {
        copyBtn.title = 'Copied!';
        setTimeout(() => { copyBtn.title = 'Copy link'; }, 2000);
      });
    });
  }
</script>
