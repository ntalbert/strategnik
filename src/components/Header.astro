---
const pathname = Astro.url.pathname;

const frameworkLinks = [
  { href: '/intelligence-layer', label: 'Intelligence Layer', desc: 'Six components of operating context' },
  { href: '/physics-of-growth', label: 'Physics of Growth', desc: 'Six forces governing B2B growth' },
  { href: '/playbooks', label: 'Playbooks', desc: 'Implementation guides' },
];

const navLinks = [
  { href: '/work', label: 'Work' },
  { href: '/thinking', label: 'Writing' },
  { href: '/services', label: 'Services' },
];

const mobileLinks = [
  { href: '/intelligence-layer', label: 'Intelligence Layer' },
  { href: '/physics-of-growth', label: 'Physics of Growth' },
  { href: '/playbooks', label: 'Playbooks' },
  { href: '/work', label: 'Work' },
  { href: '/thinking', label: 'Writing' },
  { href: '/services', label: 'Services' },
];
---

<header class="py-6 relative" style="z-index: 50;">
  <nav class="container-content">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="transition-opacity hover:opacity-80">
        <img src="/logo.png" alt="Strategnik - B2B Growth Strategy" class="h-[112px] w-auto" />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center bg-black/60 backdrop-blur-md rounded-xl px-6 py-3 gap-1">
        <!-- Framework dropdown -->
        <div class="relative group">
          <button
            class="bg-transparent border-none font-display font-extrabold text-white hover:text-gray-300 transition-colors text-lg px-3.5 py-2 cursor-pointer flex items-center gap-1.5"
            aria-haspopup="true"
            aria-expanded="false"
          >
            Framework
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </button>
          <div class="absolute top-full left-0 bg-[#0f0f14] border border-[#2b363b] rounded-lg p-2 min-w-[260px] mt-1 shadow-xl invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all pointer-events-none group-hover:pointer-events-auto">
            {frameworkLinks.map((x) => (
              <a
                href={x.href}
                class="block p-3 rounded no-underline hover:bg-[#1a1a22] transition-colors"
              >
                <div class="font-display italic text-white font-extrabold text-sm">{x.label}</div>
                <div class="text-xs text-gray-400 mt-0.5">{x.desc}</div>
              </a>
            ))}
          </div>
        </div>

        {navLinks.map((link) => (
          <a
            href={link.href}
            class="font-display font-extrabold text-white hover:text-gray-300 transition-colors text-lg px-3.5 py-2"
          >
            {link.label}
          </a>
        ))}

        <a href="/gravity-audit" class="hp-btn hp-btn--primary text-[13px] px-4 py-2.5 ml-4">
          Book a call &rarr;
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-3 bg-black/60 backdrop-blur-md rounded-xl text-white hover:text-gray-300 transition-colors"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path class="menu-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
          <path class="menu-close hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Navigation -->
  <div id="mobile-menu" class="hidden md:hidden mt-6">
    <div class="container-content">
      <div class="bg-black/60 backdrop-blur-md rounded-xl px-6 py-4 space-y-4">
        {mobileLinks.map((link) => (
          <a
            href={link.href}
            class="block py-3 min-h-[44px] flex items-center text-lg font-display font-extrabold text-white hover:text-gray-300 transition-colors"
          >
            {link.label}
          </a>
        ))}
        <a href="/gravity-audit" class="block w-full text-center py-3 min-h-[44px] mt-2 text-lg font-display font-extrabold rounded-full bg-accent text-black hover:bg-accent-hover transition-colors">
          Book a call &rarr;
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuOpen = document.querySelector('.menu-open');
  const menuClose = document.querySelector('.menu-close');

  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden');
    menuOpen?.classList.toggle('hidden');
    menuClose?.classList.toggle('hidden');
    menuBtn.setAttribute('aria-expanded', (!isOpen).toString());
  });
</script>
