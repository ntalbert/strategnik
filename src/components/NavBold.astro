---
/**
 * NavBold.astro — updated nav with Framework dropdown.
 *
 * Replaces the current nav partial in src/layouts/BaseLayout.astro (or wherever
 * the site header lives). Key change: condenses 7 top-level items into 5 with
 * a Framework dropdown exposing Intelligence Layer / Physics of Growth / Playbooks.
 *
 * All hover/dropdown behaviour is pure CSS — no JS needed. Keep your existing
 * mobile-menu JS; this is desktop layout only. Drop a mobile <details> / accordion
 * under the mobile breakpoint if you don't have one already.
 */
---

<header class="border-b border-gray-800 bg-black relative z-30">
  <div class="container-content flex items-center justify-between py-4">
    {/* Left — logo + nav */}
    <div class="flex items-center gap-8">
      <a href="/" class="font-display italic text-white font-extrabold text-lg tracking-tight no-underline">
        Strategnik
      </a>
      <div class="w-px h-5 bg-[#2b363b] hidden md:block" />

      <nav class="hidden md:flex gap-1 items-center">
        {/* Framework dropdown */}
        <div class="relative group">
          <button
            class="bg-transparent border-none text-gray-300 text-sm px-3.5 py-2 cursor-pointer flex items-center gap-1.5 group-hover:text-white transition-colors"
            aria-haspopup="true"
            aria-expanded="false"
          >
            Framework
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </button>
          <div class="absolute top-full left-0 bg-[#0f0f14] border border-[#2b363b] rounded-lg p-2 min-w-[260px] mt-1 shadow-xl invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all pointer-events-none group-hover:pointer-events-auto">
            {[
              { t: 'Intelligence Layer', d: 'Six components of operating context', href: '/intelligence-layer' },
              { t: 'Physics of Growth', d: 'Six forces governing B2B growth', href: '/physics-of-growth' },
              { t: 'Playbooks', d: 'Implementation guides', href: '/playbooks' },
            ].map((x) => (
              <a
                href={x.href}
                class="block p-3 rounded no-underline hover:bg-[#1a1a22] transition-colors"
              >
                <div class="font-display italic text-white font-extrabold text-sm">{x.t}</div>
                <div class="text-xs text-gray-400 mt-0.5">{x.d}</div>
              </a>
            ))}
          </div>
        </div>

        <a href="/work" class="text-gray-300 text-sm px-3.5 py-2 no-underline hover:text-white transition-colors">Work</a>
        <a href="/thinking" class="text-gray-300 text-sm px-3.5 py-2 no-underline hover:text-white transition-colors">Writing</a>
        <a href="/services" class="text-gray-300 text-sm px-3.5 py-2 no-underline hover:text-white transition-colors">Services</a>
      </nav>
    </div>

    {/* Right — secondary + CTA */}
    <div class="flex gap-4 items-center">
      <a href="/thinking" class="hidden md:inline text-gray-300 text-[13px] no-underline hover:text-white transition-colors">
        Field Notes
      </a>
      <a href="/gravity-audit" class="hp-btn hp-btn--primary text-[13px] px-4 py-2.5">
        Book a call →
      </a>
    </div>
  </div>
</header>
