---
import { getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import StatsLayout from '../../layouts/StatsLayout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => {
    return data.draft !== true;
  });

  // Sort by date descending for related posts selection
  const sorted = [...allPosts].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return allPosts.map((post) => ({
    params: { slug: post.slug },
    props: {
      post,
      relatedPosts: sorted
        .filter((p) => p.slug !== post.slug)
        .slice(0, 4)
        .map((p) => ({
          slug: p.slug,
          title: p.data.title,
          image: p.data.image,
          category: p.data.category,
        })),
    },
  }));
}

const { post, relatedPosts } = Astro.props;
const { Content } = await post.render();
const isStats = post.data.layout === 'stats';
---

{isStats ? (
  <StatsLayout frontmatter={post.data} relatedPosts={relatedPosts}>
    <Content />
  </StatsLayout>
) : (
  <PostLayout frontmatter={post.data} relatedPosts={relatedPosts}>
    <Content />
  </PostLayout>
)}
