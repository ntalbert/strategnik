---
import IntelligenceLayerAnimation from "../components/IntelligenceLayerAnimation";

const title = "The Intelligence Layer — Animated Explainer";
const description = "From fragmented marketing to a unified, signal-responsive operating system. See the full Intelligence Layer story in three acts.";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&family=Inter:opsz,wght@14..32,400;14..32,600;14..32,700;14..32,800;14..32,900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <IntelligenceLayerAnimation client:load />
  </body>
</html>
