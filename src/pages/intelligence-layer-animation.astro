---
import IntelligenceLayerHero from "../components/IntelligenceLayerHero";

const title = "The Context Layer — Strategnik";
const description = "From fragmented marketing to a unified, signal-responsive operating system. See the full Context Layer story.";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href="https://strategnik.com/intelligence-layer-animation/" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://strategnik.com/intelligence-layer-animation/" />
    <meta property="og:site_name" content="Strategnik" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,600;14..32,700;14..32,800;14..32,900&display=swap" rel="stylesheet" />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { background: #0a0f1a; overflow: hidden; }
    </style>
  </head>
  <body>
    <IntelligenceLayerHero client:load />
  </body>
</html>
