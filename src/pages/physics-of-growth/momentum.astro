---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';
import SectionReveal from '../../components/SectionReveal';
import MomentumCurve from '../../components/MomentumCurve';
import MomentumIndicators from '../../components/MomentumIndicators';
---

<BaseLayout
  title="Momentum — Physics of Growth"
  description="Why some growth investments compound while others dissipate. In physics, momentum equals mass times velocity. In GTM, it's the force that separates compounding systems from treadmills."
>

  <!-- ============================================ -->
  <!-- HERO — Asymmetric Split                      -->
  <!-- ============================================ -->
  <section class="mm-hero">
    <div class="container-content">
      <div class="mm-hero__grid">
        <SectionReveal client:visible direction="left" className="mm-hero__text">
          <a href="/physics-of-growth" class="mm-back-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Physics of Growth
          </a>
          <h1 class="mm-hero__headline font-display">Momentum</h1>
          <p class="mm-hero__body">
            In physics, momentum equals mass times velocity. In growth, it's the force that makes good programs get better and bad ones get worse. Every growth system is either compounding or decaying. There is no steady state.
          </p>
        </SectionReveal>

        <SectionReveal client:visible direction="right" delay={0.2} className="mm-hero__formula">
          <div class="mm-formula">
            <p class="mm-formula__equation">p = m × v</p>
            <p class="mm-formula__label">momentum = mass × velocity</p>
            <div class="mm-formula__divider"></div>
            <p class="mm-formula__translation">Growth Momentum = Market Position × Growth Rate</p>
          </div>
        </SectionReveal>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- CORE PRINCIPLE — With Momentum Curve         -->
  <!-- ============================================ -->
  <section class="mm-section">
    <div class="container-content">
      <div class="mm-split">
        <SectionReveal client:visible direction="left">
          <p class="mm-label">Core Principle</p>
          <h2 class="mm-headline font-display">Compounding vs. the treadmill</h2>
          <p class="mm-body">
            A growth program with momentum becomes easier to sustain and harder for competitors to disrupt. Established brand recognition, growing word of mouth, compounding content assets. Every dollar invested yields more than the last.
          </p>
          <p class="mm-body">
            A program without momentum requires constant force just to maintain position. Every dollar invested yields less than the last because you're fighting inertia. That's the treadmill.
          </p>
        </SectionReveal>

        <SectionReveal client:visible direction="right" delay={0.15}>
          <MomentumCurve client:visible />
        </SectionReveal>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- INDICATORS — Momentum vs. Treadmill          -->
  <!-- ============================================ -->
  <section class="mm-section mm-section--alt">
    <div class="container-content">
      <SectionReveal client:visible>
        <p class="mm-label">Diagnostics</p>
        <h2 class="mm-headline font-display">How to recognize momentum</h2>
        <p class="mm-body" style="max-width: 640px;">
          Momentum shows up in your metrics, but you have to know where to look. These two columns are the difference between a growth engine and a spending engine.
        </p>
      </SectionReveal>

      <div class="mm-indicators-wrap">
        <MomentumIndicators client:visible />
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- BUILDING MOMENTUM — 3-Column Cards           -->
  <!-- ============================================ -->
  <section class="mm-section">
    <div class="container-content">
      <SectionReveal client:visible>
        <p class="mm-label">Strategy</p>
        <h2 class="mm-headline font-display">Building momentum</h2>
        <p class="mm-body" style="max-width: 640px;">
          You can't buy momentum directly. You can only create conditions for it to develop.
        </p>
      </SectionReveal>

      <div class="mm-cards">
        <SectionReveal client:visible delay={0.1} className="mm-card mm-card--turquoise">
          <span class="mm-card__number">01</span>
          <h3 class="mm-card__title">Invest in mass before velocity</h3>
          <p class="mm-card__body">
            Market position is your "mass." A strong brand, clear positioning, and established trust make every campaign more effective. Investing in velocity without mass just burns energy.
          </p>
        </SectionReveal>

        <SectionReveal client:visible delay={0.2} className="mm-card mm-card--blue">
          <span class="mm-card__number">02</span>
          <h3 class="mm-card__title">Compound, don't campaign</h3>
          <p class="mm-card__body">
            One-off campaigns create spikes, not momentum. Build assets that compound: content that ranks long after publication, communities that grow through network effects, partnerships that expand reach over time.
          </p>
        </SectionReveal>

        <SectionReveal client:visible delay={0.3} className="mm-card mm-card--purple">
          <span class="mm-card__number">03</span>
          <h3 class="mm-card__title">Reduce friction</h3>
          <p class="mm-card__body">
            Momentum and friction are opposing forces. Every point of friction in your funnel dissipates momentum. A 10% conversion improvement often beats a 10% increase in top-of-funnel spend.
          </p>
        </SectionReveal>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- INFLECTION POINT — Asymmetric Split          -->
  <!-- ============================================ -->
  <section class="mm-section mm-section--alt">
    <div class="container-content">
      <div class="mm-split">
        <SectionReveal client:visible direction="left">
          <p class="mm-label">Critical Threshold</p>
          <h2 class="mm-headline font-display">The inflection point</h2>
          <p class="mm-body">
            Momentum has a critical threshold. Below it, every dollar of reduced investment causes disproportionate decline. Above it, the system becomes self-sustaining.
          </p>
          <p class="mm-body">
            This is why "should we scale growth spend?" is often the wrong question. The right question: "Have we achieved escape velocity?" Scaling spend before you have momentum just burns cash faster. Scaling after you have it compounds your advantage.
          </p>
        </SectionReveal>

        <SectionReveal client:visible direction="right" delay={0.2} className="mm-escape-box">
          <div class="mm-quote">
            <p class="mm-quote__text">The question isn't "should we spend more?"</p>
            <p class="mm-quote__text mm-quote__text--accent">The question is: "Have we achieved escape velocity?"</p>
            <div class="mm-quote__bar"></div>
          </div>
        </SectionReveal>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- DIAGNOSTIC QUESTIONS                         -->
  <!-- ============================================ -->
  <section class="mm-section">
    <div class="container-content">
      <div class="mm-split">
        <SectionReveal client:visible direction="left" className="mm-diag-header">
          <p class="mm-label">Self-Assessment</p>
          <h2 class="mm-headline font-display">Five questions that reveal the truth</h2>
        </SectionReveal>

        <div class="mm-diag-questions">
          <SectionReveal client:visible delay={0.1}>
            <div class="mm-diag-item">
              <span class="mm-diag-num">01</span>
              <p class="mm-diag-text">Is our CAC trending down over time, or up?</p>
            </div>
          </SectionReveal>
          <SectionReveal client:visible delay={0.15}>
            <div class="mm-diag-item">
              <span class="mm-diag-num">02</span>
              <p class="mm-diag-text">What percentage of pipeline comes from organic vs. paid sources?</p>
            </div>
          </SectionReveal>
          <SectionReveal client:visible delay={0.2}>
            <div class="mm-diag-item">
              <span class="mm-diag-num">03</span>
              <p class="mm-diag-text">How much of our content generates leads 6+ months after publication?</p>
            </div>
          </SectionReveal>
          <SectionReveal client:visible delay={0.25}>
            <div class="mm-diag-item">
              <span class="mm-diag-num">04</span>
              <p class="mm-diag-text">Are our sales cycles getting shorter or longer?</p>
            </div>
          </SectionReveal>
          <SectionReveal client:visible delay={0.3}>
            <div class="mm-diag-item mm-diag-item--highlight">
              <span class="mm-diag-num">05</span>
              <p class="mm-diag-text">Would reducing growth spend by 20% reduce results by more or less than 20%?</p>
              <p class="mm-diag-insight">If more: you don't have momentum. You have a treadmill.</p>
            </div>
          </SectionReveal>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- RELATED + CTA                                -->
  <!-- ============================================ -->
  <section class="mm-section mm-section--alt">
    <div class="container-content">
      <div class="mm-split">
        <SectionReveal client:visible direction="left">
          <p class="mm-label">Continue</p>
          <h2 class="mm-headline font-display">Related forces</h2>
          <p class="mm-body">
            Momentum doesn't operate in isolation. Friction opposes it. Mass amplifies it. Understanding the interplay is how you build systems that compound.
          </p>
        </SectionReveal>

        <SectionReveal client:visible direction="right" delay={0.15}>
          <div class="mm-related-cards">
            <a href="/physics-of-growth/friction" class="mm-related-card">
              <span class="mm-related-card__label">Opposing Force</span>
              <span class="mm-related-card__title">Friction →</span>
              <span class="mm-related-card__desc">The hidden force destroying conversion rates</span>
            </a>
            <div class="mm-related-card mm-related-card--soon">
              <span class="mm-related-card__label">Coming Soon</span>
              <span class="mm-related-card__title">Acceleration</span>
              <span class="mm-related-card__desc">How to change the rate of growth</span>
            </div>
          </div>
        </SectionReveal>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <NewsletterForm variant="compact" />

</BaseLayout>

<style>
  /* ================================================
     MOMENTUM PAGE SCOPED STYLES (mm-* namespace)
     ================================================ */

  /* Hero */
  .mm-hero {
    padding: 3rem 0 5rem;
  }
  .mm-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .mm-hero__grid {
      grid-template-columns: 3fr 2fr;
      gap: 4rem;
    }
  }
  .mm-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #9ca3af;
    font-size: 0.875rem;
    margin-bottom: 2rem;
    transition: color 0.2s;
  }
  .mm-back-link:hover { color: white; }
  .mm-hero__headline {
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 800;
    font-style: italic;
    color: white;
    line-height: 1.05;
    margin-bottom: 1.5rem;
  }
  .mm-hero__body {
    font-size: 1.125rem;
    color: #9ca3af;
    line-height: 1.7;
    max-width: 540px;
  }

  /* Formula Card */
  .mm-formula {
    background: #0d1117;
    border: 1px solid #1f2937;
    border-left: 3px solid var(--accent);
    border-radius: 12px;
    padding: 2.5rem 2rem;
    text-align: center;
  }
  .mm-formula__equation {
    font-family: 'JetBrains Mono', monospace;
    font-size: 2.5rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.5rem;
  }
  .mm-formula__label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8125rem;
    color: #6b7280;
  }
  .mm-formula__divider {
    width: 60px;
    height: 1px;
    background: #1f2937;
    margin: 1.5rem auto;
  }
  .mm-formula__translation {
    font-size: 0.9375rem;
    color: var(--accent);
    font-weight: 600;
  }

  /* Shared section styles */
  .mm-section {
    padding: 5rem 0;
  }
  .mm-section--alt {
    background: #0a0f1a;
  }
  .mm-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .mm-headline {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 800;
    font-style: italic;
    color: white;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }
  .mm-body {
    font-size: 1.0625rem;
    color: #9ca3af;
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  /* Split grid (reused) */
  .mm-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .mm-split {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  /* Momentum Curve */
  :global(.mc-container) {
    background: #0d1117;
    border: 1px solid #1f2937;
    border-radius: 12px;
    padding: 1.5rem;
  }
  :global(.mc-svg) {
    width: 100%;
    height: auto;
  }

  /* Indicators */
  .mm-indicators-wrap {
    margin-top: 2.5rem;
  }
  :global(.mi-container) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    :global(.mi-container) {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }
  :global(.mi-column) {
    background: #0d1117;
    border: 1px solid #1f2937;
    border-radius: 12px;
    overflow: hidden;
  }
  :global(.mi-column__header) {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #1f2937;
    border-top: 3px solid;
  }
  :global(.mi-column__dot) {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  :global(.mi-column__title) {
    font-size: 0.8125rem;
    font-weight: 700;
    color: white;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  :global(.mi-column__items) {
    padding: 0.5rem 0;
  }
  :global(.mi-item) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1.5rem;
  }
  :global(.mi-item__label) {
    font-size: 0.875rem;
    color: #6b7280;
  }
  :global(.mi-item__value) {
    font-size: 0.875rem;
    font-weight: 600;
    font-family: 'JetBrains Mono', monospace;
  }

  /* 3-Column Cards */
  .mm-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  @media (min-width: 1024px) {
    .mm-cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .mm-card {
    background: #0d1117;
    border: 1px solid #1f2937;
    border-radius: 12px;
    padding: 2rem 1.75rem 2.25rem;
    border-top: 3px solid transparent;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .mm-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.25);
  }
  .mm-card--turquoise { border-top-color: var(--accent); }
  .mm-card--blue { border-top-color: #0051ff; }
  .mm-card--purple { border-top-color: #8b5cf6; }
  .mm-card__number {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    color: #4b5563;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
    font-family: 'JetBrains Mono', monospace;
  }
  .mm-card__title {
    font-size: 1.125rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.75rem;
  }
  .mm-card__body {
    font-size: 0.9375rem;
    color: #9ca3af;
    line-height: 1.7;
  }

  /* Quote / Escape Velocity */
  .mm-quote {
    background: #0d1117;
    border: 1px solid #1f2937;
    border-left: 3px solid var(--accent);
    border-radius: 12px;
    padding: 2.5rem 2rem;
  }
  .mm-quote__text {
    font-size: 1.25rem;
    font-weight: 600;
    color: #6b7280;
    line-height: 1.5;
    margin-bottom: 0.5rem;
  }
  .mm-quote__text--accent {
    color: var(--accent);
    font-size: 1.375rem;
  }
  .mm-quote__bar {
    width: 40px;
    height: 3px;
    background: var(--accent);
    border-radius: 2px;
    margin-top: 1.5rem;
    opacity: 0.5;
  }

  /* Diagnostic Questions */
  .mm-diag-header {
    position: sticky;
    top: 8rem;
    align-self: start;
  }
  .mm-diag-questions {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .mm-diag-item {
    display: flex;
    gap: 1.25rem;
    align-items: baseline;
    padding: 1.5rem 0;
    border-bottom: 1px solid #1f2937;
  }
  .mm-diag-item:last-child { border-bottom: none; }
  .mm-diag-item--highlight {
    flex-direction: column;
    gap: 0.5rem;
    background: rgba(29, 226, 196, 0.04);
    border: 1px solid rgba(29, 226, 196, 0.15);
    border-radius: 12px;
    padding: 1.5rem;
    margin-top: 0.5rem;
  }
  .mm-diag-item--highlight .mm-diag-num {
    color: var(--accent);
  }
  .mm-diag-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    color: #4b5563;
    flex-shrink: 0;
    min-width: 1.5rem;
  }
  .mm-diag-text {
    font-size: 1rem;
    color: white;
    font-weight: 500;
    line-height: 1.5;
  }
  .mm-diag-insight {
    font-size: 0.9375rem;
    color: var(--accent);
    font-weight: 600;
    padding-left: 2.75rem;
  }

  /* Related Cards */
  .mm-related-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .mm-related-card {
    display: block;
    background: #0d1117;
    border: 1px solid #1f2937;
    border-left: 3px solid var(--accent);
    border-radius: 12px;
    padding: 1.5rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .mm-related-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  }
  .mm-related-card--soon {
    opacity: 0.5;
    border-left-color: #4b5563;
    pointer-events: none;
  }
  .mm-related-card__label {
    display: block;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #6b7280;
    margin-bottom: 0.5rem;
  }
  .mm-related-card__title {
    display: block;
    font-size: 1.125rem;
    font-weight: 700;
    color: white;
    margin-bottom: 0.25rem;
  }
  .mm-related-card__desc {
    display: block;
    font-size: 0.875rem;
    color: #6b7280;
  }
</style>
