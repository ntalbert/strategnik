---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionReveal from '../../components/SectionReveal';
import ForcesDiagram from '../../components/ForcesDiagram';
import ForceCards from '../../components/ForceCards';

const title = "The Physics of Growth — A Framework for GTM Investment Decisions";
const description = "Six forces govern every B2B growth system. The Physics of Growth framework explains why some GTM investments compound while others dissipate — and how to diagnose what's happening in yours.";

const relatedPosts = [
  {
    title: 'The Definitive Guide to the Physics of Marketing',
    href: '/thinking/physics-of-marketing-definitive-guide',
    description: 'The complete framework: six forces, how they interact, and how a GTM leader applies them.',
  },
  {
    title: 'Growth Programs That Look Like They\'re Failing',
    href: '/thinking/momentum-marketing-investments',
    description: 'Why the investments that compound are the ones you\'re most tempted to kill.',
  },
  {
    title: 'The Compound Cost of Friction',
    href: '/thinking/friction-problem',
    description: 'Friction doesn\'t just lose the individual lead — it trains the market you\'re hard to work with.',
  },
  {
    title: 'Scaling Too Early, Scaling Too Late',
    href: '/thinking/inflection-points',
    description: 'The two failure modes are symmetric but not equally costly.',
  },
  {
    title: 'The Funnel Math That Kills the Deal',
    href: '/thinking/funnel-math-kills-the-deal',
    description: 'Most revenue plans fail because the conversion assumptions are internally inconsistent.',
  },
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://strategnik.com" },
        { "@type": "ListItem", "position": 2, "name": "The Physics of Growth", "item": "https://strategnik.com/physics-of-growth" }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "The Physics of Growth",
      "description": description,
      "url": "https://strategnik.com/physics-of-growth",
      "author": {
        "@type": "Person",
        "name": "Nick Talbert",
        "url": "https://strategnik.com"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Strategnik",
        "url": "https://strategnik.com"
      }
    })} />
  </Fragment>

  <!-- ============================================ -->
  <!-- HERO — 60/40 Asymmetric Split -->
  <!-- ============================================ -->
  <section class="pog-hero">
    <div class="pog-hero__grid container-content">
      <!-- Left 60% -->
      <SectionReveal client:visible direction="left" className="pog-hero__text">
        <p class="pog-hero__label">Framework</p>
        <h1 class="pog-hero__headline font-display">
          The Physics of Growth
        </h1>
        <p class="pog-hero__body">
          Growth isn't art or science — it's engineering. The same laws that govern physical systems govern growth systems. Six forces determine whether your GTM investments compound or dissipate. This framework names them, explains how they interact, and gives you the diagnostic language to make better investment decisions.
        </p>
        <a href="/thinking/physics-of-marketing-definitive-guide" class="pog-hero__cta">
          Read the Definitive Guide
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px;"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </SectionReveal>

      <!-- Right 40% -->
      <SectionReveal client:visible direction="right" delay={0.2} className="pog-hero__animation">
        <ForcesDiagram client:visible />
      </SectionReveal>
    </div>

    <!-- Scroll indicator -->
    <div class="pog-hero__scroll-indicator">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pog-hero__chevron"><polyline points="6 9 12 15 18 9"/></svg>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SIX FORCES — Interactive Cards -->
  <!-- ============================================ -->
  <section class="pog-section pog-section--forces">
    <div class="container-content">
      <SectionReveal client:visible>
        <p class="pog-section__label">The Six Forces</p>
        <h2 class="pog-section__headline font-display">Every growth system is governed by six forces.</h2>
        <p class="pog-section__subtitle">
          They determine whether your GTM investments compound or dissipate. Understanding which forces are working — and which are stalling — is the difference between growth that scales and growth that plateaus.
        </p>
      </SectionReveal>

      <ForceCards client:visible />
    </div>
  </section>

  <!-- ============================================ -->
  <!-- HOW THE FORCES INTERACT — System Diagram -->
  <!-- ============================================ -->
  <section class="pog-section pog-section--interact">
    <div class="container-content">
      <div class="pog-interact__grid">
        <SectionReveal client:visible direction="left" className="pog-interact__text">
          <p class="pog-section__label">System Dynamics</p>
          <h2 class="pog-section__headline font-display">How the Forces Interact</h2>
          <p class="pog-interact__body">
            The forces don't operate in isolation. Friction dampens momentum. Mass amplifies surface area's effect. Escape velocity requires a specific combination of momentum and reduced friction. The interplay creates a natural sequence to GTM investment:
          </p>
          <ol class="pog-interact__sequence">
            <li><strong>Build mass</strong> — brand, content, positioning, credibility</li>
            <li><strong>Reduce friction</strong> — audit the buyer journey, eliminate unnecessary steps</li>
            <li><strong>Generate momentum</strong> — consistent investment starts to compound</li>
            <li><strong>Expand surface area</strong> — extend into new channels and contexts</li>
            <li><strong>Achieve escape velocity</strong> — the market itself does your distribution</li>
          </ol>
          <a href="/thinking/physics-of-marketing-definitive-guide" class="pog-interact__link">
            Read the full framework
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </SectionReveal>

        <SectionReveal client:visible direction="right" delay={0.2} className="pog-interact__diagram">
          <ForcesDiagram client:visible size="large" />
        </SectionReveal>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- ORIGIN STORY — Asymmetric Dark Section -->
  <!-- ============================================ -->
  <section class="pog-section pog-section--origin">
    <div class="container-content">
      <div class="pog-origin__grid">
        <SectionReveal client:visible direction="left" className="pog-origin__quote-col">
          <blockquote class="pog-origin__pullquote">
            "The companies that break out aren't the ones with better tactics. They're the ones operating with an intuitive grasp of the forces acting on their growth system."
          </blockquote>
        </SectionReveal>

        <SectionReveal client:visible direction="right" delay={0.15} className="pog-origin__prose-col">
          <p class="pog-section__label">Origin</p>
          <h2 class="pog-section__headline font-display">Where this came from</h2>
          <p class="pog-origin__body">
            After 20 years watching B2B SaaS companies make growth investment decisions, I noticed patterns. The companies that broke out and the ones that stalled often had similar products, teams, and markets. The difference was usually in how they understood the forces acting on their growth system.
          </p>
          <p class="pog-origin__body">
            The physics metaphor emerged from trying to explain these patterns to CEOs and boards. When you frame growth investment in terms of momentum, friction, and mass, people suddenly see their situation differently. They stop asking "why isn't this working?" and start asking "which force are we fighting?"
          </p>
        </SectionReveal>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- RELATED READING — Card Row -->
  <!-- ============================================ -->
  <section class="pog-section pog-section--reading">
    <div class="container-content">
      <SectionReveal client:visible>
        <p class="pog-section__label">Go Deeper</p>
        <h2 class="pog-section__headline font-display">Related Reading</h2>
      </SectionReveal>

      <div class="pog-reading__row">
        {relatedPosts.map((post, i) => (
          <SectionReveal client:visible delay={i * 0.08}>
            <a href={post.href} class="pog-reading__card">
              <h3 class="pog-reading__card-title">{post.title}</h3>
              <p class="pog-reading__card-desc">{post.description}</p>
              <span class="pog-reading__card-link">
                Read
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </span>
            </a>
          </SectionReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- CTA — Full-Bleed -->
  <!-- ============================================ -->
  <section class="pog-section pog-section--cta">
    <div class="container-content" style="text-align: center;">
      <SectionReveal client:visible>
        <h2 class="pog-cta__headline font-display">Diagnose Your Growth Physics</h2>
        <p class="pog-cta__body">
          Find out which forces are working and which are stalling your growth. The Gravity Audit maps the six forces against your current state and identifies where the system is losing energy.
        </p>
        <div class="pog-cta__buttons">
          <a href="/gravity-audit" class="pog-cta__btn pog-cta__btn--primary">
            Get Your Gravity Audit
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:20px;height:20px;"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="/pricing" class="pog-cta__btn pog-cta__btn--secondary">
            See pricing
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </SectionReveal>
    </div>
  </section>

</BaseLayout>

<style>
  /* ========================================
     PHYSICS OF GROWTH — Swiss Modernism 2.0
     12-column grid, asymmetric layouts
     ======================================== */

  :root {
    --pog-bg-1: #0d1117;
    --pog-bg-2: #161b22;
    --pog-bg-3: #0a0f1a;
    --pog-turquoise: #1de2c4;
    --pog-turquoise-dim: rgba(29, 226, 196, 0.15);
  }

  /* ---------- HERO ---------- */
  .pog-hero {
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--pog-bg-1);
    position: relative;
    padding: 8rem 0 4rem;
  }

  .pog-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .pog-hero__grid {
      grid-template-columns: 3fr 2fr;
      gap: 4rem;
    }
  }

  .pog-hero__label {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pog-turquoise);
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  .pog-hero__headline {
    font-size: clamp(2.25rem, 5vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #fff;
    font-weight: 700;
    margin-bottom: 1.75rem;
    max-width: 16ch;
  }

  .pog-hero__body {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #afafb6;
    max-width: 55ch;
    margin-bottom: 2.5rem;
  }

  .pog-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 2rem;
    background: var(--pog-turquoise);
    color: var(--pog-bg-1);
    font-weight: 700;
    font-size: 0.9375rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.15s ease;
  }

  .pog-hero__cta:hover {
    background: #4ae8d0;
    color: var(--pog-bg-1);
    transform: translateY(-1px);
  }

  .pog-hero__animation {
    max-width: 100%;
  }

  .pog-hero__scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
  }

  .pog-hero__chevron {
    width: 24px;
    height: 24px;
    color: #494950;
    animation: pog-bounce 2s ease-in-out infinite;
  }

  @keyframes pog-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ---------- SECTIONS (base) ---------- */
  .pog-section {
    padding: 5rem 0;
  }

  .pog-section__label {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pog-turquoise);
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .pog-section__headline {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: #fff;
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .pog-section__subtitle {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #95959d;
    max-width: 60ch;
    margin-bottom: 3rem;
  }

  /* ---------- FORCES SECTION ---------- */
  .pog-section--forces {
    padding: 6rem 0;
    background: var(--pog-bg-3);
  }

  /* ForceCards grid styles */
  :global(.force-cards-grid) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    :global(.force-cards-grid) {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
  }

  :global(.force-card__anchor) {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  :global(.force-card) {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: box-shadow 0.25s ease, border-color 0.25s ease;
    height: 100%;
  }

  :global(.force-card:hover) {
    border-color: var(--card-accent, rgba(255,255,255,0.12));
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3), 0 0 0 1px var(--card-accent-dim, transparent);
  }

  :global(.force-card__header) {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  :global(.force-card__icon) {
    flex-shrink: 0;
  }

  :global(.force-card__name) {
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.01em;
    margin: 0;
  }

  :global(.force-card__body) {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  :global(.force-card__label) {
    display: block;
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7a7a85;
    margin-bottom: 0.25rem;
    font-weight: 600;
  }

  :global(.force-card__physics),
  :global(.force-card__gtm) {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #afafb6;
    margin: 0;
  }

  :global(.force-card__footer) {
    margin-top: auto;
    padding-top: 0.5rem;
  }

  :global(.force-card__link) {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--card-accent, #1de2c4);
    transition: gap 0.2s ease;
  }

  :global(.force-card:hover .force-card__link) {
    gap: 0.625rem;
  }

  :global(.force-card__soon) {
    font-size: 0.8125rem;
    color: #62626a;
    font-style: italic;
  }

  /* ---------- INTERACTION SECTION ---------- */
  .pog-section--interact {
    padding: 6rem 0;
    background: var(--pog-bg-2);
  }

  .pog-interact__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .pog-interact__grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  .pog-interact__body {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #afafb6;
    margin-bottom: 1.5rem;
  }

  .pog-interact__sequence {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem 0;
    counter-reset: seq;
  }

  .pog-interact__sequence li {
    counter-increment: seq;
    position: relative;
    padding-left: 2rem;
    margin-bottom: 0.75rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: #95959d;
  }

  .pog-interact__sequence li::before {
    content: counter(seq);
    position: absolute;
    left: 0;
    top: 0;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--pog-turquoise);
    width: 1.25rem;
    height: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(29, 226, 196, 0.3);
    border-radius: 4px;
  }

  .pog-interact__sequence li strong {
    color: #fff;
    font-weight: 600;
  }

  .pog-interact__link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--pog-turquoise);
    text-decoration: none;
    transition: gap 0.2s ease, color 0.2s ease;
  }

  .pog-interact__link:hover {
    color: #4ae8d0;
    gap: 0.75rem;
  }

  /* ---------- ORIGIN SECTION ---------- */
  .pog-section--origin {
    padding: 6rem 0;
    background: var(--pog-bg-1);
  }

  .pog-origin__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }

  @media (min-width: 1024px) {
    .pog-origin__grid {
      grid-template-columns: 2fr 3fr;
      gap: 4rem;
    }
  }

  .pog-origin__pullquote {
    font-size: clamp(1.25rem, 2.5vw, 1.625rem);
    line-height: 1.45;
    color: #fff;
    font-weight: 400;
    font-style: italic;
    border-left: 3px solid var(--pog-turquoise);
    padding-left: 1.5rem;
    margin: 0;
  }

  .pog-origin__body {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #afafb6;
    margin-bottom: 1rem;
  }

  /* ---------- RELATED READING SECTION ---------- */
  .pog-section--reading {
    padding: 6rem 0;
    background: var(--pog-bg-3);
  }

  .pog-reading__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .pog-reading__row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .pog-reading__row {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1280px) {
    .pog-reading__row {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .pog-reading__card {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding: 1.25rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 10px;
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    height: 100%;
  }

  .pog-reading__card:hover {
    border-color: rgba(29, 226, 196, 0.3);
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.2);
  }

  .pog-reading__card-title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.35;
    margin: 0;
  }

  .pog-reading__card-desc {
    font-size: 0.8125rem;
    line-height: 1.55;
    color: #7a7a85;
    flex: 1;
    margin: 0;
  }

  .pog-reading__card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--pog-turquoise);
    margin-top: auto;
  }

  .pog-reading__card:hover .pog-reading__card-link {
    gap: 0.5rem;
  }

  /* ---------- CTA SECTION ---------- */
  .pog-section--cta {
    padding: 8rem 0;
    background: linear-gradient(180deg, var(--pog-bg-2) 0%, #080c12 100%);
  }

  .pog-cta__headline {
    font-size: clamp(2rem, 4vw, 3rem);
    color: #fff;
    font-weight: 700;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .pog-cta__body {
    font-size: 1.125rem;
    line-height: 1.75;
    color: #95959d;
    max-width: 50ch;
    margin: 0 auto 2.5rem;
  }

  .pog-cta__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    align-items: center;
  }

  .pog-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 1rem 2.25rem;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.15s ease, color 0.2s ease;
  }

  .pog-cta__btn--primary {
    background: var(--pog-turquoise);
    color: var(--pog-bg-1);
  }

  .pog-cta__btn--primary:hover {
    background: #4ae8d0;
    color: var(--pog-bg-1);
    transform: translateY(-1px);
  }

  .pog-cta__btn--secondary {
    background: transparent;
    color: var(--pog-turquoise);
    border: 1px solid rgba(29, 226, 196, 0.3);
    padding: 0.9375rem 2.25rem;
  }

  .pog-cta__btn--secondary:hover {
    border-color: var(--pog-turquoise);
    color: #4ae8d0;
    transform: translateY(-1px);
  }

  /* ---------- REDUCED MOTION ---------- */
  @media (prefers-reduced-motion: reduce) {
    .pog-hero__chevron {
      animation: none;
    }
  }

  /* ---------- RESPONSIVE: Mobile ---------- */
  @media (max-width: 768px) {
