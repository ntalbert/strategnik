      transition: none;
    }

    .il-faq__chevron {
      transition: none;
    }

    .il-timeline__dot--pulse {
      animation: none;
    }

    .il-discipline {
      transition: none;
    }
  }

  /* ---------- Responsive: Tablet ---------- */
  @media (max-width: 1024px) {
    .il-timeline {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    .il-timeline__track {
      display: none;
    }

    .il-audits {
      grid-template-columns: 1fr 1fr;
    }

    .il-deliverables {
      grid-template-columns: 1fr;
    }

    .il-tab {
      min-width: 120px;
      padding: 0.875rem 1rem;
      font-size: 0.8rem;
    }
  }

  /* ---------- Responsive: Mobile ---------- */
  @media (max-width: 768px) {
    .il-hero {
      min-height: 70vh;
    }

    .il-hero__content {
      padding-top: 6rem;
      padding-bottom: 3rem;
    }

    .il-section {
      padding: 3.5rem 0;
    }

    .il-section--components,
    .il-section--comparison,
    .il-section--maturity,
    .il-section--engagement {
      padding: 4rem 0;
    }

    .il-comparison {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .il-comparison__divider {
      width: 100%;
      height: 1px;
      margin: 1.5rem 0;
    }

    .il-timeline {
      grid-template-columns: 1fr;
      gap: 1.5rem;
