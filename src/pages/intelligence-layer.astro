---
import BaseLayout from '../layouts/BaseLayout.astro';
import LayerTransformation from '../components/LayerTransformation';
import ComponentTabs from '../components/ComponentTabs';
import IntelligenceLayerSpec from '../components/IntelligenceLayerSpec';
import MaturityTimeline from '../components/MaturityTimeline';
import StatsCounter from '../components/StatsCounter';
import DisciplineGrid from '../components/DisciplineGrid';
import FaqAccordion from '../components/FaqAccordion';
import SectionReveal from '../components/SectionReveal';
import FloatingCta from '../components/FloatingCta';

const title = "The Intelligence Layer — What AI Agents Actually Need to Run Your Marketing";
const description = "The Intelligence Layer is the machine-readable operating context that makes AI-native marketing possible. Six components. One shared foundation. Built for Series B through pre-IPO B2B SaaS companies.";

const faqData = [
  {
    question: "What is the Intelligence Layer?",
    answer: "The Intelligence Layer is a machine-readable operating context — the encoded knowledge of your brand, your buyers, your competitive position, your content architecture, and your measurement framework — built so that every AI tool, every agent, and every team member works from the same shared foundation."
  },
  {
    question: "How is this different from hiring a fractional CMO?",
    answer: "A fractional CMO provides leadership and strategy. When they leave, the strategy leaves with them. The Intelligence Layer is infrastructure — it persists after the engagement ends."
  },
  {
    question: "How long does it take to build the Intelligence Layer?",
    answer: "The diagnostic takes 2-4 weeks. The full build sprint takes 30-90 days depending on company complexity."
  },
  {
    question: "What does the Intelligence Layer cost?",
    answer: "The diagnostic ranges from $2,500-$25,000. The full build sprint ranges from $25,000-$75,000. The ongoing advisor retainer is $5,000-$15,000 per month."
  },
  {
    question: "Can we build this internally?",
    answer: "Your team can run the system once it is built. Building it requires understanding how AI models ingest context, how agents learn from data structures, and how to encode brand and competitive intelligence in formats agents can actually use."
  },
  {
    question: "We already have a CMO and marketing team. Is this a replacement?",
    answer: "No. The Intelligence Layer gives your existing team a new set of operating instructions for a world where agents are part of the team. The CMO steers the layer. The layer steers everything else."
  },
  {
    question: "What happens after the build?",
    answer: "The layer is delivered with full training for your internal team. Others engage in an ongoing advisor retainer — a monthly signal review. The layer does not go stale because the retainer is the update cycle."
  }
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "The Intelligence Layer",
      "provider": {
        "@type": "Organization",
        "name": "Strategnik",
        "url": "https://strategnik.com"
      },
      "description": "The Intelligence Layer is the machine-readable operating context that makes AI-native marketing possible. Six components — brand spec, ICP context, competitive framing, content architecture, machine readability schema, and measurement targets.",
      "serviceType": "AI Marketing Infrastructure",
      "areaServed": "Worldwide",
      "audience": {
        "@type": "BusinessAudience",
        "audienceType": "Series B through pre-IPO B2B SaaS companies"
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://strategnik.com" },
        { "@type": "ListItem", "position": 2, "name": "The Intelligence Layer", "item": "https://strategnik.com/intelligence-layer" }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqData.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
      }))
    })} />
  </Fragment>

  <!-- ============================================ -->
  <!-- HERO — 60/40 Asymmetric Split -->
  <!-- ============================================ -->
  <section class="il-hero">
    <div class="il-hero__grid container-content">
      <!-- Left 60% -->
      <SectionReveal client:visible direction="left" className="il-hero__text">
        <p class="il-hero__label">The Intelligence Layer</p>
        <h1 class="il-hero__headline font-display">
          What AI Agents Actually Need to Run Your Marketing
        </h1>
        <p class="il-hero__body">
          Most companies gave their team AI access and called it a strategy. What they actually built is a faster typing pool. The Intelligence Layer is the foundational operating context that makes AI-native marketing real — the encoded knowledge of your brand, your buyers, and your market, structured so every agent and every team member works from the same shared foundation.
        </p>
        <a href="/gravity-audit" class="il-hero__cta">
          Get Your Gravity Audit
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:18px;height:18px;"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </SectionReveal>

      <!-- Right 40% -->
      <SectionReveal client:visible direction="right" delay={0.2} className="il-hero__animation">
        <LayerTransformation client:visible />
      </SectionReveal>
    </div>

    <!-- Scroll indicator -->
    <div class="il-hero__scroll-indicator">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="il-hero__chevron"><polyline points="6 9 12 15 18 9"/></svg>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SIX COMPONENTS — IntelligenceLayerSpec -->
  <!-- ============================================ -->
  <section class="il-section il-section--components">
    <div class="container-content">
      <div class="il-components__honeycomb-wrap">
        <img
          src="/images/posts/il-six-components-honeycomb.png"
          alt="Six components of the Intelligence Layer arranged in a honeycomb architecture"
          class="il-components__honeycomb-img"
        />
      </div>

      <IntelligenceLayerSpec client:visible />
    </div>
  </section>

  <!-- ============================================ -->
  <!-- MATURITY MODEL — Full-Bleed Dark -->
  <!-- ============================================ -->
  <section class="il-section il-section--maturity">
    <div class="container-content">
      <SectionReveal client:visible>
        <h2 class="il-section__headline font-display">The Five Stages of AI Marketing Maturity</h2>
        <p class="il-section__subtitle">
          You cannot reach stage 3 or beyond without stage 2. The layer is the gate.
        </p>
      </SectionReveal>

      <img
        src="/images/posts/il-maturity-staircase.png"
        alt="Five stages of AI marketing maturity — from fragmented humans at stage 1, through Intelligence Layer built at stage 2, to humans plus AI, humans plus agents, and fully proactive agents at stage 5."
        class="il-maturity__img"
      />

      <MaturityTimeline client:visible />
    </div>
  </section>

  <!-- ============================================ -->
  <!-- WHY NOW — Stats Section -->
  <!-- ============================================ -->
  <section class="il-section il-section--stats">
    <div class="container-content">
      <SectionReveal client:visible>
        <h2 class="il-section__headline font-display">The Window Is Narrower Than It Appears</h2>
        <p class="il-section__subtitle">
          The gap between experimenting and scaling is where the Intelligence Layer operates.
        </p>
      </SectionReveal>

      <StatsCounter client:visible />
    </div>
  </section>

  <!-- ============================================ -->
  <!-- FOUR DISCIPLINES — 2x2 Grid -->
  <!-- ============================================ -->
  <section class="il-section il-section--disciplines">
    <div class="container-content">
      <SectionReveal client:visible>
        <h2 class="il-section__headline font-display">Four Disciplines That Rarely Coexist</h2>
        <p class="il-section__subtitle">
          Building the Intelligence Layer requires simultaneous fluency across four areas that almost never exist in one person or one agency.
        </p>
      </SectionReveal>

      <DisciplineGrid client:visible />

      <SectionReveal client:visible delay={0.4}>
        <p class="il-disciplines__closer">
          The last CMO candidate who was equally fluent across all four doesn't exist in the hiring market. That's the moat.
        </p>
      </SectionReveal>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- FAQ — Accordion, Narrow Column -->
  <!-- ============================================ -->
  <section class="il-section il-section--faq">
    <div class="container-narrow">
      <SectionReveal client:visible>
        <h2 class="il-section__headline font-display">Frequently Asked Questions</h2>
      </SectionReveal>

      <FaqAccordion client:visible />
    </div>
  </section>

  <!-- ============================================ -->
  <!-- FINAL CTA — Full-Bleed -->
  <!-- ============================================ -->
  <section class="il-section il-section--cta" id="il-footer-cta">
    <div class="container-content" style="text-align: center;">
      <SectionReveal client:visible>
        <h2 class="il-cta__headline font-display">Before You Hire, Build, or Buy</h2>
        <p class="il-cta__body">
          Find out what's missing. The diagnostic maps your marketing function across all six layers and delivers the gap analysis, the architecture blueprint, and the build plan.
        </p>
        <p class="il-cta__sub">
          Two weeks. One deliverable. The foundation for everything that comes next.
        </p>
        <a href="/gravity-audit" class="il-cta__btn">
          Get Your Gravity Audit
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:20px;height:20px;"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </SectionReveal>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- STICKY FLOATING CTA -->
  <!-- ============================================ -->
  <FloatingCta client:visible />

</BaseLayout>

<style>
  /* ========================================
     INTELLIGENCE LAYER — Swiss Modernism 2.0
     12-column grid, asymmetric layouts
     ======================================== */

  :root {
    --il-bg-1: #0d1117;
    --il-bg-2: #161b22;
    --il-bg-3: #0a0f1a;
    --il-turquoise: #1de2c4;
    --il-turquoise-dim: rgba(29, 226, 196, 0.15);
  }

  /* ---------- HERO ---------- */
  .il-hero {
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--il-bg-1);
    position: relative;
    padding: 8rem 0 4rem;
  }

  .il-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .il-hero__grid {
      grid-template-columns: 3fr 2fr;
      gap: 4rem;
    }
  }

  .il-hero__label {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--il-turquoise);
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  .il-hero__headline {
    font-size: clamp(2.25rem, 5vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: #fff;
    font-weight: 700;
    margin-bottom: 1.75rem;
    max-width: 16ch;
  }

  .il-hero__body {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #afafb6;
    max-width: 55ch;
    margin-bottom: 2.5rem;
  }

  .il-hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 2rem;
    background: var(--il-turquoise);
    color: var(--il-bg-1);
    font-weight: 700;
    font-size: 0.9375rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.15s ease;
  }

  .il-hero__cta:hover {
    background: #4ae8d0;
    color: var(--il-bg-1);
    transform: translateY(-1px);
  }

  .il-hero__animation {
    max-width: 100%;
  }

  /* Scroll indicator */
  .il-hero__scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
  }

  .il-hero__chevron {
    width: 24px;
    height: 24px;
    color: #494950;
    animation: il-bounce 2s ease-in-out infinite;
  }

  @keyframes il-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }

  /* ---------- SECTIONS (base) ---------- */
  .il-section {
    padding: 5rem 0;
  }

  .il-section__headline {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    color: #fff;
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .il-section__subtitle {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #95959d;
    max-width: 60ch;
    margin-bottom: 3rem;
  }

  /* ---------- COMPONENTS SECTION ---------- */
  .il-section--components {
    padding: 6rem 0;
    background: var(--il-bg-3);
  }

  .il-components__honeycomb-wrap {
    margin-bottom: 3rem;
    text-align: center;
  }

  .il-components__honeycomb-img {
    width: 100%;
    max-width: 900px;
    margin: 0 auto;
    border-radius: 12px;
    display: block;
  }

  /* ---------- MATURITY SECTION ---------- */
  .il-section--maturity {
    padding: 6rem 0;
    background: var(--il-bg-2);
  }

  .il-maturity__img {
    width: 100%;
    border-radius: 12px;
    margin: 2rem 0 3rem;
  }

  /* ---------- STATS SECTION ---------- */
  .il-section--stats {
    padding: 6rem 0;
    background: var(--il-bg-1);
  }

  /* ---------- DISCIPLINES SECTION ---------- */
  .il-section--disciplines {
    padding: 6rem 0;
    background: var(--il-bg-3);
  }

  .il-disciplines__closer {
    font-size: 1rem;
    color: #95959d;
    max-width: 60ch;
    margin-top: 2.5rem;
  }

  /* ---------- FAQ SECTION ---------- */
  .il-section--faq {
    padding: 5rem 0;
    background: var(--il-bg-2);
  }

  /* ---------- FINAL CTA ---------- */
  .il-section--cta {
    padding: 8rem 0;
    background: linear-gradient(180deg, var(--il-bg-1) 0%, #080c12 100%);
  }

  .il-cta__headline {
    font-size: clamp(2rem, 4vw, 3rem);
    color: #fff;
    font-weight: 700;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .il-cta__body {
    font-size: 1.125rem;
    line-height: 1.75;
    color: #95959d;
    max-width: 50ch;
    margin: 0 auto 1rem;
  }

  .il-cta__sub {
    font-size: 1rem;
    color: #95959d;
    margin-bottom: 2.5rem;
  }

  .il-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    background: var(--il-turquoise);
    color: var(--il-bg-1);
    font-weight: 700;
    font-size: 1rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.15s ease;
  }

  .il-cta__btn:hover {
    background: #4ae8d0;
    color: var(--il-bg-1);
    transform: translateY(-1px);
  }

  /* ---------- REDUCED MOTION ---------- */
  @media (prefers-reduced-motion: reduce) {
    .il-hero__chevron {
      animation: none;
    }
  }

  /* ---------- RESPONSIVE: Mobile ---------- */
  @media (max-width: 768px) {
    .il-hero {
      min-height: auto;
      padding: 6rem 0 3rem;
    }

    .il-hero__cta,
    .il-cta__btn {
      width: 100%;
      justify-content: center;
      text-align: center;
    }

    .il-section {
      padding: 3.5rem 0;
    }

    .il-section--components,
    .il-section--maturity,
    .il-section--stats,
    .il-section--disciplines {
      padding: 4rem 0;
    }

    .il-section--cta {
      padding: 5rem 0;
    }
  }
</style>
