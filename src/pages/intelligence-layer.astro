---
import BaseLayout from '../layouts/BaseLayout.astro';
import LayerTransformation from '../components/LayerTransformation';

const title = "The Intelligence Layer — What AI Agents Actually Need to Run Your Marketing";
const description = "The Intelligence Layer is the machine-readable operating context that makes AI-native marketing possible. Six components. One shared foundation. Built for Series B through pre-IPO B2B SaaS companies.";

const faqData = [
  {
    question: "What is the Intelligence Layer?",
    answer: "The Intelligence Layer is a machine-readable operating context — the encoded knowledge of your brand, your buyers, your competitive position, your content architecture, and your measurement framework — built so that every AI tool, every agent, and every team member works from the same shared foundation. It is not a document, a prompt template, or a one-time brand exercise. It is a living operating system that updates as the market moves."
  },
  {
    question: "How is this different from hiring a fractional CMO?",
    answer: "A fractional CMO provides leadership and strategy. When they leave, the strategy leaves with them. The Intelligence Layer is infrastructure — it persists after the engagement ends. Your team and your agents operate from it indefinitely. Building it requires simultaneous fluency in GTM strategy, technical infrastructure, creative production systems, and AI-native thinking — four disciplines that almost never coexist in a single hire."
  },
  {
    question: "How long does it take to build the Intelligence Layer?",
    answer: "The diagnostic takes 2-4 weeks. The full build sprint takes 30-90 days depending on company complexity. This is not a digital transformation initiative or an enterprise software deployment. It is a focused build that encodes the brand knowledge, market intelligence, and measurement framework that already exist in your organization — scattered across people's heads, old decks, and CRM fields — into a machine-readable operating context."
  },
  {
    question: "What does the Intelligence Layer cost?",
    answer: "The diagnostic ranges from $2,500-$25,000 depending on scope (external audit vs. deep internal audit). The full build sprint ranges from $25,000-$75,000. The ongoing advisor retainer is $5,000-$15,000 per month. A full transformation engagement runs $75,000-$150,000+. For comparison: a single CMO hire costs $350K+ fully loaded per year. The Intelligence Layer sprint costs less than one quarter of that salary and produces infrastructure that persists."
  },
  {
    question: "Can we build this internally?",
    answer: "Your team can run the system once it is built. Building the Intelligence Layer requires understanding how AI models ingest context, how agents learn from data structures, and how to encode brand and competitive intelligence in formats agents can actually use. That is not marketing ops — it is a different discipline. Strategnik builds it, trains your team, and hands it off. They operate it."
  },
  {
    question: "We already have a CMO and marketing team. Is this a replacement?",
    answer: "No. The Intelligence Layer is not here to replace your CMO or your team. It gives them a new set of operating instructions for a world where agents are part of the team. The CMO stays. The team stays. What changes is the infrastructure they operate from. The CMO steers the layer. The layer steers everything else."
  },
  {
    question: "What happens after the build?",
    answer: "The layer is delivered with full training for your internal team. Some companies operate it independently from day one. Others engage in an ongoing advisor retainer — a monthly signal review that asks what ranked, what converted, what messaging missed, and what shifted in the competitive landscape. The layer updates. New context pushes to all connected agents and tools. The layer does not go stale because the retainer is the update cycle."
  }
];

const components = [
  {
    id: "brand",
    num: "01",
    label: "Brand + Voice",
    color: "#1de2c4",
    title: "Brand + Voice Spec",
    desc: "Tone, editorial standards, banned language, writing style rules — encoded so every agent produces on-brand work without requiring human review of every output. Not a style guide PDF. A machine-readable operating spec agents reference autonomously. Your brand becomes infrastructure, not a document someone forgets to check."
  },
  {
    id: "icp",
    num: "02",
    label: "ICP + Buyers",
    color: "#60a5fa",
    title: "ICP + Buyer Context",
    desc: "Ideal customer profiles, buying committee maps, pain hierarchy, objection framing, persona-level messaging — so agents know who they're talking to, why it matters, and what the alternatives look like. The strategic intelligence that turns generic outreach into precision targeting."
  },
  {
    id: "competitive",
    num: "03",
    label: "Competitive",
    color: "#c084fc",
    title: "Competitive Framing",
    desc: "Positioning against alternatives, displacement narratives, win/loss context, differentiated value claims — so every piece of content reinforces the market stance. Not static. Updated as the competitive landscape shifts. When the framing changes in the layer, it changes everywhere."
  },
  {
    id: "content",
    num: "04",
    label: "Content",
    color: "#f59e0b",
    title: "Content Architecture",
    desc: "Topic cluster design with semantic entity relationships. Content atomization frameworks. Template structures per content type that embed schema, heading hierarchy, and entity definitions at creation. Internal linking architecture that signals topical authority. Question-answer pair libraries mapped to buying stage — the atomic units that AI Overviews, Perplexity, and ChatGPT cite."
  },
  {
    id: "machine",
    num: "05",
    label: "Machine",
    color: "#06b6d4",
    title: "Machine Readability + Distribution Schema",
    desc: "JSON-LD structured data per page type. Entity definitions in formats machines parse. AI crawler accessibility via llms.txt and robots.txt policy. Multi-surface optimization for Google Search, AI Overviews, Perplexity, ChatGPT, and Gemini. Citation architecture — the signals that make LLMs treat your content as citable rather than paraphrasable. The difference between being found and being cited is structure."
  },
  {
    id: "measurement",
    num: "06",
    label: "Measurement",
    color: "#ef4444",
    title: "Measurement Targets",
    desc: "Revenue influence metrics, conversion benchmarks, time-to-personalization goals, decision accuracy signals — so the system knows what success looks like and feedback loops can steer toward it. Not dashboards that report what happened. Feedback loops that steer what happens next. The agent fleet learns. The system adapts. Marketing becomes a precision instrument."
  }
];

const beforeAfterData = [
  { without: '"Write me a blog post about X"', withLayer: 'Agent generates from keyword brief, brand spec, and ICP — autonomously. Ships with schema and entity markup from day one.' },
  { without: 'Competitive response takes 2-4 weeks', withLayer: 'CMO updates framing in one place. Changes propagate to website, ads, email, agent prompts. Live by end of day.' },
  { without: 'Team of 20 produces 8-12 pieces/month', withLayer: 'Team of 5 produces 20-40 pieces/month. Campaign launch: 3-5 days instead of 3-4 weeks.' },
  { without: 'Invisible to ChatGPT, Perplexity, AI Overviews', withLayer: 'Every page structured for AI citation from creation. llms.txt published. Entity definitions declared. Passage-level citability built in.' },
  { without: 'Hiring to scale output', withLayer: 'Architecture that scales without headcount. ROI within 60-90 days of deployment.' },
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "The Intelligence Layer",
      "provider": {
        "@type": "Organization",
        "name": "Strategnik",
        "url": "https://strategnik.com"
      },
      "description": "The Intelligence Layer is the machine-readable operating context that makes AI-native marketing possible. Six components — brand spec, ICP context, competitive framing, content architecture, machine readability schema, and measurement targets — encoded so every AI tool and team member works from the same foundation.",
      "serviceType": "AI Marketing Infrastructure",
      "areaServed": "Worldwide",
      "audience": {
        "@type": "BusinessAudience",
        "audienceType": "Series B through pre-IPO B2B SaaS companies"
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://strategnik.com" },
        { "@type": "ListItem", "position": 2, "name": "The Intelligence Layer", "item": "https://strategnik.com/intelligence-layer" }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqData.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
      }))
    })} />
  </Fragment>

  <!-- ============================================ -->
  <!-- HERO — Full-bleed background image w/ overlay -->
  <!-- ============================================ -->
  <section class="il-hero">
    <div class="il-hero__bg">
      <img src="/images/posts/il-before-after-transformation.png" alt="Before and after the Intelligence Layer — fragmented teams with disconnected strategy versus a unified system where every team and agent works from shared context" />
    </div>
    <div class="il-hero__overlay"></div>
    <div class="il-hero__content container-narrow">
      <p class="il-hero__label">The Intelligence Layer</p>
      <h1 class="il-hero__headline font-display">
        What AI Agents Actually Need to Run Your Marketing
      </h1>
      <p class="il-hero__body">
        Most companies gave their team AI access and called it a strategy. What they actually built is a faster typing pool. The Intelligence Layer is the foundational operating context that makes AI-native marketing real — the encoded knowledge of your brand, your buyers, and your market, structured so every agent and every team member works from the same shared foundation.
      </p>
      <p class="il-hero__kicker">
        Your AI is still a chatbot. Here's what an operating system looks like.
      </p>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- WHAT CHANGES — Animation (moved up from below) -->
  <!-- ============================================ -->
  <section class="il-section il-section--comparison il-animate">
    <div class="container-content">
      <h2 class="il-display-headline il-display-headline--xl font-display">What Changes When the Layer Is Running</h2>
      <p class="il-section__body" style="max-width: 65ch; margin-bottom: 48px;">
        Same prompt. Same AI. Completely different output. Watch what happens when context replaces guessing.
      </p>
      <LayerTransformation client:visible />
    </div>
  </section>

  <!-- ============================================ -->
  <!-- THE PROBLEM -->
  <!-- ============================================ -->
  <section class="il-section il-section--problem il-animate">
    <div class="container-narrow">
      <div class="il-problem__accent-bar"></div>
      <h2 class="il-section__headline font-display">The Problem Nobody Is Solving</h2>
      <p class="il-section__body">
        In a typical 20-person marketing org, strategy enters at the top and degrades at every handoff. The content team interprets the brief one way. Demand gen interprets it differently. Web does its own thing. Events uses whatever deck was built last quarter. The buyer encounters five different companies. Brand dilutes. Pipeline slows.
      </p>
      <p class="il-section__body">
        Now add AI to that system. AI amplifies output, not quality. More content produced faster from a fragmented system means more fragmented content at higher velocity. Every agent prompt starts from zero — no brand memory, no ICP knowledge, no competitive framing. A chatbot trained on fragmented context produces fragmented output — faster.
      </p>
      <p class="il-section__body il-section__body--bold">
        The question isn't "how do we use AI in marketing?" It's "what does our AI actually know about us — and is that enough to act on?"
      </p>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SIX COMPONENTS — Tabbed Interface -->
  <!-- ============================================ -->
  <section class="il-section il-section--components il-animate">
    <div class="il-components__honeycomb-wrap container-content">
      <img src="/images/posts/il-six-components-honeycomb.png" alt="Six components of the Intelligence Layer arranged in a honeycomb architecture" class="il-components__honeycomb-img" />
    </div>
    <div class="container-content">
      <h2 class="il-display-headline font-display">Six Components. One Source of Truth.</h2>
      <p class="il-section__body" style="max-width: 65ch;">
        The Intelligence Layer serves two audiences. The first is your internal agents and team — giving them context to produce on-brand, on-strategy output. The second is every external machine your buyer consults — ChatGPT, Perplexity, AI Overviews. The layer makes your company legible to both.
      </p>

      <!-- Tab Bar -->
      <div class="il-tabs" role="tablist" aria-label="Intelligence Layer Components">
        {components.map((comp, i) => (
          <button
            class={`il-tab ${i === 0 ? 'il-tab--active' : ''}`}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`panel-${comp.id}`}
            id={`tab-${comp.id}`}
            data-tab={comp.id}
            data-color={comp.color}
            style={i === 0 ? `--tab-color: ${comp.color}` : ''}
          >
            <span class="il-tab__num">{comp.num}</span>
            <span class="il-tab__label">{comp.label}</span>
          </button>
        ))}
      </div>

      <!-- Tab Panels -->
      <div class="il-panels">
        {components.map((comp, i) => (
          <div
            class={`il-panel ${i === 0 ? 'il-panel--active' : ''}`}
            role="tabpanel"
            id={`panel-${comp.id}`}
            aria-labelledby={`tab-${comp.id}`}
            data-panel={comp.id}
            style={`--panel-color: ${comp.color}`}
          >
            <div class="il-panel__inner">
              <span class="il-panel__num" style={`color: ${comp.color}`}>{comp.num}</span>
              <h3 class="il-panel__title">{comp.title}</h3>
              <p class="il-panel__desc">{comp.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- (moved to after hero) -->

  <!-- ============================================ -->
  <!-- MATURITY MODEL — Staircase + Timeline -->
  <!-- ============================================ -->
  <section class="il-section il-section--maturity il-animate">
    <div class="container-content">
      <h2 class="il-section__headline font-display">The Five Stages of AI Marketing Maturity</h2>
      <p class="il-section__body" style="max-width: 65ch;">
        You cannot reach stage 3 or beyond without stage 2. The layer is the gate.
      </p>
      <img src="/images/posts/il-maturity-staircase.png" alt="Five stages of AI marketing maturity — from fragmented humans at stage 1, through Intelligence Layer built at stage 2, to humans plus AI, humans plus agents, and fully proactive agents at stage 5." class="il-maturity__img" />

      <!-- Horizontal Step Timeline -->
      <div class="il-timeline">
        <div class="il-timeline__track"></div>

        <div class="il-timeline__step il-timeline__step--muted">
          <div class="il-timeline__dot" style="background: #494950;"></div>
          <div class="il-timeline__content">
            <span class="il-timeline__stage" style="color: #7a7a85;">Stage 1</span>
            <h3 class="il-timeline__title">Fragmented Humans</h3>
            <p class="il-timeline__desc">All humans, all silos. Strategy briefed to 5+ teams. Handoffs dilute everything. Adding AI makes it worse.</p>
          </div>
        </div>

        <div class="il-timeline__step il-timeline__step--active">
          <div class="il-timeline__dot il-timeline__dot--pulse" style="background: #1de2c4;"></div>
          <div class="il-timeline__badge">THE UNLOCK</div>
          <div class="il-timeline__content">
            <span class="il-timeline__stage" style="color: #1de2c4;">Stage 2 — The Sprint</span>
            <h3 class="il-timeline__title">Intelligence Layer Built</h3>
            <p class="il-timeline__desc">All six components encoded. Shared operating context installed. AI tools can now be wired in. 30-90 day engagement.</p>
          </div>
        </div>

        <div class="il-timeline__step">
          <div class="il-timeline__dot" style="background: #c084fc;"></div>
          <div class="il-timeline__content">
            <span class="il-timeline__stage" style="color: #c084fc;">Stages 3-4 — The Retainer</span>
            <h3 class="il-timeline__title">Humans + AI + Agents</h3>
            <p class="il-timeline__desc">Teams prompt from shared context. Agents run content, SEO, nurture autonomously. Precision at scale. The feedback loop compounds.</p>
          </div>
        </div>

        <div class="il-timeline__step il-timeline__step--muted">
          <div class="il-timeline__dot" style="background: #494950;"></div>
          <div class="il-timeline__content">
            <span class="il-timeline__stage" style="color: #7a7a85;">Stage 5 — The Horizon</span>
            <h3 class="il-timeline__title">Proactive Agents</h3>
            <p class="il-timeline__desc">Agents detect signals and deploy autonomously. Humans govern strategy. Marketing as infrastructure. Internal team owns.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- WHY NOW — Accent Bar Divider -->
  <!-- ============================================ -->
  <div class="il-divider--gradient"></div>
  <section class="il-section il-section--whynow il-animate">
    <div class="container-narrow">
      <h2 class="il-section__headline font-display">The Window Is Narrower Than It Appears</h2>
      <div class="il-whynow__body">
        <p>Gartner projects 60% of brands will use agentic AI for one-to-one interactions by 2028, replacing channel-based marketing. BCG expects agentic AI to handle over 20% of marketing's workload within two to three years. Accenture has deployed 14 AI agents across their 600-person marketing team — campaign steps reduced from 135 to 85.</p>
        <p>Vercel replaced 9 of 10 inbound SDRs with a single AI agent in six weeks. Customer support hiring is down 65% in two years. AI-native B2B companies are running eight-figure businesses with 3 human employees and 20+ AI agents, spending 23% of revenue on inference costs rather than headcount.</p>
        <p>But McKinsey's data reveals the gap: while 50% of CMOs rank generative AI as a top-three investment, it ranked 17th of 20 in actual execution priorities.</p>
      </div>
      <p class="il-whynow__stat">
        62% experimenting. Only 23% scaling. The 39-point gap is where the Intelligence Layer operates.
      </p>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- THE ENGAGEMENT — Two Ways In -->
  <!-- ============================================ -->
  <section class="il-section il-section--engagement il-animate">
    <div class="container-content">
      <h2 class="il-section__headline font-display">Two Ways In. One Destination.</h2>
      <p class="il-section__body" style="max-width: 65ch;">
        Both paths lead to the same three deliverables: a gap analysis, an architecture blueprint, and a sequenced build plan.
      </p>

      <div class="il-audits">
        <div class="il-audit il-audit--external">
          <span class="il-audit__badge">Light entry</span>
          <h3 class="il-audit__title">External Audit</h3>
          <p class="il-audit__timeline">1-2 weeks. No internal access required.</p>
          <ul class="il-audit__list">
            <li>Digital presence audit</li>
            <li>AI citation footprint assessment</li>
            <li>Competitive landscape scan</li>
            <li>Content coherence review</li>
            <li>Schema and AI crawler accessibility audit</li>
          </ul>
        </div>

        <div class="il-audit il-audit--internal">
          <span class="il-audit__badge il-audit__badge--accent">Deep entry</span>
          <h3 class="il-audit__title">Internal Audit</h3>
          <p class="il-audit__timeline">2-4 weeks. With internal access.</p>
          <ul class="il-audit__list">
            <li>Everything in the external audit</li>
            <li>CRM structure and signal mapping</li>
            <li>Content systems and workflow review</li>
            <li>Team workflow and AI usage analysis</li>
            <li>Full six-component gap analysis</li>
          </ul>
        </div>
      </div>

      <h3 class="il-deliverables__headline font-display">Three Deliverables. Regardless of Which Audit.</h3>
      <div class="il-deliverables">
        <div class="il-deliverable">
          <span class="il-deliverable__num">01</span>
          <h4 class="il-deliverable__title">Gap Analysis</h4>
          <p class="il-deliverable__desc">Which of the six layer components exist today, which are missing, and which are present but broken. Includes AI discoverability scorecard showing where you are and are not visible to the machines your buyers consult.</p>
        </div>
        <div class="il-deliverable">
          <span class="il-deliverable__num">02</span>
          <h4 class="il-deliverable__title">Architecture Blueprint</h4>
          <p class="il-deliverable__desc">What the Intelligence Layer looks like for your company, your market, your stage, and your team. Not a generic framework — a blueprint built to specific context.</p>
        </div>
        <div class="il-deliverable">
          <span class="il-deliverable__num">03</span>
          <h4 class="il-deliverable__title">Build Plan</h4>
          <p class="il-deliverable__desc">Sequenced by what to fix first, what to build next, and where agents create the most leverage. Actionable whether you engage further or hand it to your internal team.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- FOUR DISCIPLINES — 2x2 Grid -->
  <!-- ============================================ -->
  <div class="il-divider--accent"></div>
  <section class="il-section il-section--disciplines il-animate">
    <div class="container-content">
      <h2 class="il-section__headline font-display">Four Disciplines That Rarely Coexist</h2>
      <p class="il-section__body" style="max-width: 65ch;">
        Building the Intelligence Layer requires simultaneous fluency across four areas that almost never exist in one person or one agency:
      </p>

      <div class="il-disciplines-grid">
        <div class="il-discipline" style="--disc-color: #1de2c4;">
          <div class="il-discipline__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h3 class="il-discipline__title">GTM Strategy</h3>
          <p class="il-discipline__desc">ICP definition, positioning architecture, pipeline mechanics, competitive framing, buying committee mapping.</p>
        </div>

        <div class="il-discipline" style="--disc-color: #60a5fa;">
          <div class="il-discipline__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
          </div>
          <h3 class="il-discipline__title">Technical Infrastructure</h3>
          <p class="il-discipline__desc">Data architecture, CRM design, platform orchestration, API integrations, signal mapping.</p>
        </div>

        <div class="il-discipline" style="--disc-color: #f59e0b;">
          <div class="il-discipline__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3 class="il-discipline__title">Creative Production Systems</h3>
          <p class="il-discipline__desc">Brand voice encoding, editorial standards, content frameworks, style specifications.</p>
        </div>

        <div class="il-discipline" style="--disc-color: #c084fc;">
          <div class="il-discipline__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10H12V2z"/><path d="M20.66 7A10 10 0 0 0 14 2v5.34z"/></svg>
          </div>
          <h3 class="il-discipline__title">AI-Native Thinking</h3>
          <p class="il-discipline__desc">How models ingest context, how agents learn from structured data, how to build systems they can reliably operate within.</p>
        </div>
      </div>

      <p class="il-disciplines__closer">
        The last CMO candidate who was equally fluent across all four doesn't exist in the hiring market. That's the moat.
      </p>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- RELATED READING -->
  <!-- ============================================ -->
  <section class="il-section il-section--reading il-animate">
    <div class="container-narrow">
      <h2 class="il-section__headline font-display">Related Reading</h2>
      <ul class="il-reading-list">
        <li><a href="/thinking/your-ai-is-still-a-chatbot">Your AI Is Still a Chatbot. Here's What an Operating System Looks Like.</a></li>
        <li><a href="/thinking/six-components-of-an-intelligence-layer">The Six Components of an Intelligence Layer</a></li>
        <li><a href="/thinking/from-chatbot-to-agent-fleet">From Chatbot to Agent Fleet: The Five Stages of AI Marketing Maturity</a></li>
        <li><a href="/thinking/why-b2b-content-doesnt-show-up-in-chatgpt">Why Your B2B Content Doesn't Show Up in ChatGPT</a></li>
        <li><a href="/gravity-audit">The Gravity Audit — AI Visibility & GTM Diagnostic</a></li>
        <li><a href="/playbooks">See the 25 Intelligence Layer plays</a></li>
        <li><a href="/pricing">See pricing</a></li>
      </ul>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- FAQ — Accordion -->
  <!-- ============================================ -->
  <div class="il-divider--gradient"></div>
  <section class="il-section il-section--faq il-animate">
    <div class="container-narrow">
      <h2 class="il-section__headline font-display">Frequently Asked Questions</h2>
      <div class="il-faq-list">
        {faqData.map((faq, i) => (
          <div class="il-faq" data-faq>
            <button class="il-faq__trigger" aria-expanded="false" aria-controls={`faq-answer-${i}`}>
              <span class="il-faq__question">{faq.question}</span>
              <svg class="il-faq__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
