</style>

<script>
  // ===== Tab Switching =====
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.il-tab');
    const panels = document.querySelectorAll('.il-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const target = tab.getAttribute('data-tab');
        const color = tab.getAttribute('data-color');

        // Deactivate all
        tabs.forEach(t => {
          t.classList.remove('il-tab--active');
          t.setAttribute('aria-selected', 'false');
          t.style.removeProperty('--tab-color');
        });
        panels.forEach(p => p.classList.remove('il-panel--active'));

        // Activate selected
        tab.classList.add('il-tab--active');
        tab.setAttribute('aria-selected', 'true');
        tab.style.setProperty('--tab-color', color);

        const panel = document.querySelector(`[data-panel="${target}"]`);
        if (panel) {
          panel.classList.add('il-panel--active');
          // Re-trigger animation
          panel.style.animation = 'none';
          panel.offsetHeight; // force reflow
          panel.style.animation = '';
        }
      });
    });

    // ===== FAQ Accordion =====
    const faqItems = document.querySelectorAll('[data-faq]');

    faqItems.forEach(item => {
      const trigger = item.querySelector('.il-faq__trigger');
      const answer = item.querySelector('.il-faq__answer');

      trigger.addEventListener('click', () => {
        const isOpen = item.classList.contains('il-faq--open');

        // Close all
        faqItems.forEach(f => {
          f.classList.remove('il-faq--open');
          const ans = f.querySelector('.il-faq__answer');
          ans.style.maxHeight = null;
          f.querySelector('.il-faq__trigger').setAttribute('aria-expanded', 'false');
        });

        // Open clicked (if it was closed)
        if (!isOpen) {
          item.classList.add('il-faq--open');
          answer.style.maxHeight = answer.scrollHeight + 24 + 'px';
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });

    // ===== Scroll-triggered Animations =====
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!prefersReduced) {
      const animateEls = document.querySelectorAll('.il-animate');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('il-animate--visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

      animateEls.forEach(el => observer.observe(el));
    } else {
      // Make everything visible immediately
      document.querySelectorAll('.il-animate').forEach(el => {
        el.classList.add('il-animate--visible');
      });
    }

    // ===== Sticky Floating CTA =====
    const stickyCta = document.getElementById('il-sticky-cta');
    const footerCta = document.getElementById('il-footer-cta');

    if (stickyCta && footerCta) {
      const handleScroll = () => {
        const scrollY = window.scrollY;
        const footerRect = footerCta.getBoundingClientRect();
        const footerVisible = footerRect.top < window.innerHeight && footerRect.bottom > 0;

        if (scrollY > 500 && !footerVisible) {
          stickyCta.classList.add('il-sticky-cta--visible');
        } else {
          stickyCta.classList.remove('il-sticky-cta--visible');
        }
      };

      window.addEventListener('scroll', handleScroll, { passive: true });
      handleScroll(); // Initial check
    }
  });
</script>
