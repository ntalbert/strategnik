---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist or has moved.">
  <section class="section min-h-[60vh] flex items-center justify-center">
    <div class="container-narrow text-center">
      <p class="text-6xl font-bold text-turquoise-500 mb-4">404</p>
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">Page not found</h1>
      <p class="text-lg text-gray-400 mb-8 max-w-md mx-auto">
        The page you're looking for doesn't exist or has moved. Here are some places to start:
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="px-6 py-3 bg-turquoise-500 text-black font-semibold rounded-lg hover:bg-turquoise-400 transition-colors">
          Homepage
        </a>
        <a href="/thinking" class="px-6 py-3 border border-gray-700 text-white font-semibold rounded-lg hover:border-gray-500 transition-colors">
          Read the Blog
        </a>
        <a href="/intelligence-layer" class="px-6 py-3 border border-gray-700 text-white font-semibold rounded-lg hover:border-gray-500 transition-colors">
          Intelligence Layer
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
