---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import BrandGravityHero from '../components/BrandGravityHero.astro';
import SectionReveal from '../components/SectionReveal';
import HeroBold from '../components/HeroBold';
import GravityAuditFlow from '../components/GravityAuditFlow';
import ForceCardsBold from '../components/ForceCardsBold';
import { getCollection } from 'astro:content';

// Fetch posts from content collection
const contentPosts = await getCollection('posts', ({ data }) => data.draft !== true);

const posts = contentPosts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  date: post.data.date,
  image: post.data.image,
  url: `/thinking/${post.slug}`,
  type: 'Article',
}));

// Case studies with dates for sorting
const caseStudies = [
  {
    title: "Building 17 Nurture Paths",
    description: "How lifecycle segmentation cut lead-to-value time from 47 days to 19",
    image: "/case-studies/hero-image-03.png",
    url: '/case-studies/lifecycle-archetypes',
    date: new Date('2025-01-15'),
    type: 'Case Study',
  },
  {
    title: "Developer-to-Enterprise Pipeline",
    description: "Turning GitHub stars into six-figure deals for open source AI",
    image: "/case-studies/hero-image-01.png",
    url: '/case-studies/developer-discovery',
    date: new Date('2025-01-10'),
    type: 'Case Study',
  },
  {
    title: "Propensity Scoring That Works",
    description: "How data governance made predictive models 30% more accurate",
    image: "/case-studies/hero-image-02.png",
    url: '/case-studies/propensity-scoring',
    date: new Date('2025-01-05'),
    type: 'Case Study',
  },
];

// Combine and sort by date
const allContent = [...posts, ...caseStudies]
  .sort((a, b) => b.date.getTime() - a.date.getTime());
---

<BaseLayout title="Strategnik — GTM Architecture & the Intelligence Layer for AI-Native Marketing" description="GTM architecture and the Intelligence Layer for Series B through pre-IPO B2B SaaS. Positioning, pipeline, content systems, and AI-native marketing built on the Physics of Growth™ framework.">
  <!-- Brand Gravity Hero Section -->
  <BrandGravityHero overlayOpacity={0.25}>
    <!-- Hero - HeroBold replaces previous hero grid -->
    <HeroBold client:load />

    <!-- Inline Gravity Audit capture below hero -->
    <GravityAuditFlow client:visible />

    <script>
      // Rotating words animation (kept for compatibility)
      (function() {
        const words = document.querySelectorAll('.hp-rotating-word');
        if (!words.length) return;
        let current = 0;

        setInterval(() => {
          const prev = current;
          current = (current + 1) % words.length;

          words[prev].classList.remove('hp-rotating-word--active');
          words[prev].classList.add('hp-rotating-word--exit');

          words[current].classList.remove('hp-rotating-word--exit');
          words[current].classList.add('hp-rotating-word--active');

          // Clean up exit class after transition
          setTimeout(() => {
            words[prev].classList.remove('hp-rotating-word--exit');
          }, 500);
        }, 2500);
      })();
    </script>

    <!-- Physics of Growth — ForceCardsBold replaces previous framework cards -->
    <ForceCardsBold client:visible />

    <!-- Featured Content Carousel -->
    <section class="pt-10 pb-32">
      <div class="container-content">
        <p class="text-caption text-blue-bright tracking-wide mb-6 font-bold">Latest</p>
        <div class="relative">
          <!-- Left Arrow -->
          <button
            id="carousel-prev"
            class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 z-10 w-10 h-10 bg-gray-900/80 backdrop-blur-sm border border-gray-700 rounded-full flex items-center justify-center text-white hover:bg-gray-800 hover:border-gray-600 transition-all shadow-lg hidden md:flex"
            aria-label="Previous"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </button>

          <!-- Carousel Container -->
          <div id="carousel-container" class="flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide scroll-smooth">
            {allContent.map((item) => (
              <a
                href={item.url}
                class="group flex-shrink-0 w-[320px] md:w-[400px] hp-carousel__card snap-start"
              >
                <div class="aspect-video bg-gray-800 relative overflow-hidden rounded-t-xl">
                  {item.image ? (
                    <img
                      src={item.image}
                      alt={item.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-gray-800 to-gray-900">
                      <div class="w-12 h-12 rounded-lg bg-gray-900 border border-gray-800 flex items-center justify-center">
                        <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                        </svg>
                      </div>
                    </div>
                  )}
                  <div class="absolute top-3 left-3">
                    <span class={`hp-carousel__tag ${item.type === 'Case Study' ? 'hp-carousel__tag--blue' : ''}`}>
                      {item.type}
                    </span>
                  </div>
                </div>
                <div class="p-5">
                  <h3 class="font-semibold text-lg text-white group-hover:text-accent transition-colors mb-2 line-clamp-2">{item.title}</h3>
                  <p class="text-sm text-gray-400 line-clamp-2 mb-3">{item.description}</p>
                  <span class="text-xs font-bold text-accent uppercase tracking-wider">Read</span>
                </div>
              </a>
            ))}
          </div>

          <!-- Right Arrow -->
          <button
            id="carousel-next"
            class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 z-10 w-10 h-10 bg-gray-900/80 backdrop-blur-sm border border-gray-700 rounded-full flex items-center justify-center text-white hover:bg-gray-800 hover:border-gray-600 transition-all shadow-lg hidden md:flex"
            aria-label="Next"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>
      </div>
    </section>

    <script>
      const carousel = document.getElementById('carousel-container');
      const prevBtn = document.getElementById('carousel-prev');
      const nextBtn = document.getElementById('carousel-next');

      if (carousel && prevBtn && nextBtn) {
        const cardWidth = 400 + 24;

        prevBtn.addEventListener('click', () => {
          carousel.scrollBy({ left: -cardWidth, behavior: 'smooth' });
        });

        nextBtn.addEventListener('click', () => {
          carousel.scrollBy({ left: cardWidth, behavior: 'smooth' });
        });

        const updateButtons = () => {
          prevBtn.style.opacity = carousel.scrollLeft <= 0 ? '0.3' : '1';
          prevBtn.style.pointerEvents = carousel.scrollLeft <= 0 ? 'none' : 'auto';

          const maxScroll = carousel.scrollWidth - carousel.clientWidth;
          nextBtn.style.opacity = carousel.scrollLeft >= maxScroll - 10 ? '0.3' : '1';
          nextBtn.style.pointerEvents = carousel.scrollLeft >= maxScroll - 10 ? 'none' : 'auto';
        };

        carousel.addEventListener('scroll', updateButtons);
        updateButtons();
      }
    </script>
  </BrandGravityHero>

  <!-- The Problem Section — Asymmetric Split -->
  <section class="py-20 md:py-32 bg-black">
    <div class="container-content">
      <div class="hp-split__grid">
        <SectionReveal client:visible direction="left">
          <h2 class="text-display text-white font-bold">Most companies gave their team AI and called it a strategy.</h2>
        </SectionReveal>

        <SectionReveal client:visible direction="right" delay={0.15}>
          <p class="text-body-lg text-gray-400 mb-6">
            Output went up. Pipeline didn't move. Five teams interpreting the same brief five different ways — now doing it faster. The buyer encounters five different companies. Brand dilutes. Cycles lengthen.
          </p>

          <p class="text-body-lg text-white font-bold mb-10">
            The question isn't how to use AI in marketing. It's what your AI actually knows about you — and whether that's enough to act on.
          </p>

          <div class="flex flex-col gap-3">
            <a href="/intelligence-layer" class="text-accent hover:text-white transition-colors font-bold">
              The Intelligence Layer →
            </a>
            <a href="/gravity-audit" class="text-accent hover:text-white transition-colors font-bold">
              Gravity Audit →
            </a>
            <a href="/services" class="text-accent hover:text-white transition-colors font-bold">
              All services →
            </a>
            <a href="/pricing" class="text-accent hover:text-white transition-colors font-bold">
              Pricing →
            </a>
          </div>
        </SectionReveal>
      </div>
    </div>
  </section>

  <!-- Selected Work — Card Grid -->
  <section class="py-20 md:py-32 bg-black border-t border-gray-800">
    <div class="container-content">
      <SectionReveal client:visible>
        <p class="text-caption text-blue-bright tracking-wide mb-4 font-bold">Work</p>
        <h2 class="text-display text-white font-bold mb-10">Selected Work</h2>
      </SectionReveal>

      <div class="hp-work__grid">
        <SectionReveal client:visible delay={0.1} className="hp-work__card">
          <span class="hp-work__tag">AI / Visual GenAI</span>
          <h3 class="text-xl text-white font-bold mb-3">BRIA AI</h3>
          <p class="text-body text-gray-400 mb-4">Built GTM ops from zero for visual AI platform serving EA, Disney, P&G. Signal-driven growth systems drove 120% MAU lift.</p>
          <a href="/case-studies/developer-discovery" class="text-accent text-sm font-bold hover:text-white transition-colors">Read case study →</a>
        </SectionReveal>

        <SectionReveal client:visible delay={0.2} className="hp-work__card">
          <span class="hp-work__tag hp-work__tag--blue">Enterprise / Telco</span>
          <h3 class="text-xl text-white font-bold mb-3">Lumen Technologies</h3>
          <p class="text-body text-gray-400 mb-4">26% improvement in data integrity, 30% lift in propensity scores. Data governance that made predictive models work.</p>
          <a href="/case-studies/propensity-scoring" class="text-accent text-sm font-bold hover:text-white transition-colors">Read case study →</a>
        </SectionReveal>

        <SectionReveal client:visible delay={0.3} className="hp-work__card">
          <span class="hp-work__tag hp-work__tag--purple">API Security</span>
          <h3 class="text-xl text-white font-bold mb-3">Wallarm</h3>
          <p class="text-body text-gray-400 mb-4">20% increase in growth-sourced pipeline, 18% conversion rate uplift. Full-funnel GTM optimization.</p>
          <a href="/experience" class="text-accent text-sm font-bold hover:text-white transition-colors">View details →</a>
        </SectionReveal>
      </div>

      <div class="mt-10">
        <a href="/experience" class="text-accent hover:text-white transition-colors font-bold">
          See all experience →
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ Section — Sticky Header + Questions -->
  <section class="py-20 md:py-32 bg-black border-t border-gray-800">
    <div class="container-content">
      <div class="hp-faq__grid">
        <SectionReveal client:visible direction="left" className="hp-faq__header">
          <h2 class="text-display text-white font-bold">Frequently Asked Questions</h2>
        </SectionReveal>

        <div class="hp-faq__questions">
          <SectionReveal client:visible delay={0.1}>
            <div class="hp-faq__item">
              <h3 class="text-body-lg text-white font-bold mb-3">What is the Intelligence Layer?</h3>
              <p class="text-body text-gray-400">The Intelligence Layer is a machine-readable operating context — brand spec, ICP hierarchy, competitive framing, content architecture, distribution schema, and measurement targets — encoded so every AI tool, agent, and team member works from the same shared foundation. It is not a document or a prompt template. It is a living system that updates as the market moves and compounds over time.</p>
            </div>
          </SectionReveal>

          <SectionReveal client:visible delay={0.15}>
            <div class="hp-faq__item">
              <h3 class="text-body-lg text-white font-bold mb-3">Does the Intelligence Layer replace marketing leadership?</h3>
              <p class="text-body text-gray-400">No. Leadership sets direction — the Intelligence Layer encodes that direction into a system the entire team and every AI tool operates from. Strategy stops living in one person's head and becomes shared operating context that persists, compounds, and updates as the market moves. The CMO still steers. The layer makes sure every output reflects what they decided.</p>
            </div>
          </SectionReveal>

          <SectionReveal client:visible delay={0.2}>
            <div class="hp-faq__item">
              <h3 class="text-body-lg text-white font-bold mb-3">How does the Physics of Growth™ framework work?</h3>
              <p class="text-body text-gray-400">Physics of Growth™ applies physics principles to B2B growth systems. Momentum — why some investments compound while others dissipate. Friction — the hidden forces destroying conversion rates and slowing pipeline. Gravity — the organic pull that attracts prospects versus requiring outbound to chase them. Every engagement starts by diagnosing which force is working against you, then building the systems to shift it.</p>
            </div>
          </SectionReveal>

          <SectionReveal client:visible delay={0.25}>
            <div class="hp-faq__item">
              <h3 class="text-body-lg text-white font-bold mb-3">Who is this for?</h3>
              <p class="text-body text-gray-400">Series B through pre-IPO B2B SaaS companies — typically $10M to $150M ARR — where the CEO is asking whether to hire a marketing leader or build an AI-native system, or where the team has AI tools and nothing feels different. The Intelligence Layer diagnostic is also relevant for companies about to make a significant marketing hire and wondering whether the investment would be better spent on architecture.</p>
            </div>
          </SectionReveal>

          <SectionReveal client:visible delay={0.3}>
            <div class="hp-faq__item">
              <h3 class="text-body-lg text-white font-bold mb-3">What does an engagement cost?</h3>
              <p class="text-body text-gray-400">The diagnostic runs $2,500–$25,000 depending on scope. The full Intelligence Layer build sprint is $25,000–$75,000 over 30–90 days. An ongoing advisor retainer is $5,000–$15,000 per month. For context: a single CMO hire costs $350K+ fully loaded per year. The build sprint costs less than one quarter of that salary and produces a system that compounds.</p>
            </div>
          </SectionReveal>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the Intelligence Layer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Intelligence Layer is a machine-readable operating context — brand spec, ICP hierarchy, competitive framing, content architecture, distribution schema, and measurement targets — encoded so every AI tool, agent, and team member works from the same shared foundation. It is not a document or a prompt template. It is a living system that updates as the market moves and compounds over time."
          }
        },
        {
          "@type": "Question",
          "name": "Does the Intelligence Layer replace marketing leadership?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Leadership sets direction — the Intelligence Layer encodes that direction into a system the entire team and every AI tool operates from. Strategy stops living in one person's head and becomes shared operating context that persists, compounds, and updates as the market moves. The CMO still steers. The layer makes sure every output reflects what they decided."
          }
        },
        {
          "@type": "Question",
          "name": "How does the Physics of Growth framework work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Physics of Growth applies physics principles to B2B growth systems. Momentum — why some investments compound while others dissipate. Friction — the hidden forces destroying conversion rates and slowing pipeline. Gravity — the organic pull that attracts prospects versus requiring outbound to chase them. Every engagement starts by diagnosing which force is working against you, then building the systems to shift it."
          }
        },
        {
          "@type": "Question",
          "name": "Who is Strategnik for?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Series B through pre-IPO B2B SaaS companies — typically $10M to $150M ARR — where the CEO is asking whether to hire a marketing leader or build an AI-native system, or where the team has AI tools and nothing feels different. The Intelligence Layer diagnostic is also relevant for companies about to make a significant marketing hire and wondering whether the investment would be better spent on architecture."
          }
        },
        {
          "@type": "Question",
          "name": "What does an engagement cost?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The diagnostic runs $2,500 to $25,000 depending on scope. The full Intelligence Layer build sprint is $25,000 to $75,000 over 30 to 90 days. An ongoing advisor retainer is $5,000 to $15,000 per month. For context: a single CMO hire costs $350K+ fully loaded per year. The build sprint costs less than one quarter of that salary and produces a system that compounds."
          }
        }
      ]
    })} />
  </Fragment>

  <!-- Combined CTA + Newsletter — Asymmetric -->
  <section class="py-20 md:py-32 bg-black border-t border-gray-800">
    <div class="container-content">
      <div class="hp-split__grid">
        <SectionReveal client:visible direction="left">
          <h2 class="text-display text-white font-bold mb-6">Before you hire, build, or buy</h2>
          <p class="text-body-lg text-gray-400 mb-8">
            Know what you're actually missing. A 30-minute conversation — no pitch, no deck. What's happening in your growth system and how to think about it.
          </p>
          <a href="mailto:nick@strategnik.com" class="hp-btn hp-btn--primary">
            Start a conversation
          </a>
        </SectionReveal>

        <SectionReveal client:visible direction="right" delay={0.2}>
          <div class="hp-newsletter__card">
            <p class="text-caption text-accent tracking-wide mb-3 font-bold">Newsletter</p>
            <h3 class="text-xl text-white font-bold mb-3">Get the field notes</h3>
            <p class="text-sm text-gray-400 mb-6">
              Observations on B2B SaaS growth — frameworks, teardowns, and what's working.
            </p>
            <form action="https://formspree.io/f/xpqlbarl" method="POST" class="flex gap-3" id="hp-newsletter-form">
              <input
                type="email"
                name="email"
                required
                placeholder="you@company.com"
                class="flex-1 px-4 py-3 bg-gray-900 border border-gray-700 rounded-lg text-white text-sm placeholder-gray-500 focus:outline-none focus:border-accent transition-colors"
              />
              <button type="submit" class="px-5 py-3 bg-accent text-black font-bold rounded-lg text-sm hover:bg-accent-hover transition-colors whitespace-nowrap">
                Subscribe
              </button>
            </form>
          </div>
        </SectionReveal>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ================================================
     HOMEPAGE SCOPED STYLES (hp-* namespace)
     Mirrors services page sv-* pattern
     ================================================ */

  /* Hero Grid */
  .hp-hero__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .hp-hero__grid {
      grid-template-columns: 3fr 2fr;
      gap: 4rem;
    }
  }

  /* Hero text pop */
  h1[data-animate-hero] {
    text-shadow: 0 2px 20px rgba(0, 0, 0, 0.6), 0 4px 40px rgba(0, 0, 0, 0.4);
  }
  h1[data-animate-hero] .hp-rotating-word--active {
    text-shadow: 0 2px 30px rgba(29, 226, 196, 0.3), 0 4px 40px rgba(0, 0, 0, 0.5);
  }

  /* Section headings pop */
  .hp-section-pop {
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.5);
  }

  /* Rotating Words */
  .hp-rotating-wrapper {
    display: inline-block;
    position: relative;
    overflow: hidden;
    vertical-align: bottom;
    height: 1.15em;
  }
  .hp-rotating-words {
    display: inline-block;
    position: relative;
  }
  .hp-rotating-word {
    display: block;
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transform: translateY(100%);
    transition: opacity 0.5s ease, transform 0.5s ease;
    color: var(--accent);
    white-space: nowrap;
  }
  .hp-rotating-word--active {
    position: relative;
    opacity: 1;
    transform: translateY(0);
  }
  .hp-rotating-word--exit {
    opacity: 0;
    transform: translateY(-100%);
  }

  /* Stat Cards (inline, below CTAs) */
  .hp-stat-inline {
    border-left: 2px solid rgba(29, 226, 196, 0.4);
    padding-left: 1rem;
  }
  .hp-stat-inline__number {
    display: block;
    font-size: 1.5rem;
    font-weight: 900;
    color: white;
    line-height: 1.1;
  }
  .hp-stat-inline__label {
    font-size: 0.6875rem;
    color: #afafb6;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 0.125rem;
  }

  /* Buttons */
  .hp-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 2rem;
    font-weight: 700;
    border-radius: 8px;
    transition: all 0.2s ease;
    font-size: 0.9375rem;
  }
  .hp-btn--primary {
    background: white;
    color: black;
  }
  .hp-btn--primary:hover {
    background: #e5e5e5;
  }
  .hp-btn--ghost {
    border: 1px solid #4b5563;
    color: white;
  }
  .hp-btn--ghost:hover {
    border-color: white;
  }

  /* Carousel Cards */
  .hp-carousel__card {
    background: rgba(22, 27, 34, 0.8);
    backdrop-filter: blur(8px);
    border-radius: 12px;
    border: 1px solid #313135;
    border-left: 3px solid var(--accent);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    overflow: hidden;
  }
  .hp-carousel__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.3);
  }
  .hp-carousel__tag {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
    font-size: 0.6875rem;
    font-weight: 600;
    background: rgba(29, 226, 196, 0.15);
    color: var(--accent);
    backdrop-filter: blur(8px);
  }
  .hp-carousel__tag--blue {
    background: rgba(0, 81, 255, 0.15);
    color: #6b9fff;
  }

  /* Framework Cards */
  .hp-framework__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 1024px) {
    .hp-framework__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .hp-fw-card {
    background: rgba(22, 27, 34, 0.7);
    backdrop-filter: blur(8px);
    border-radius: 12px;
    border: 1px solid rgba(49, 49, 53, 0.5);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .hp-fw-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.25);
  }
  .hp-fw-card__inner {
    padding: 2rem 1.75rem 2.25rem;
    border-top: 3px solid transparent;
    border-radius: 12px 12px 0 0;
  }
  .hp-fw-card--turquoise .hp-fw-card__inner { border-top-color: var(--accent); }
  .hp-fw-card--blue .hp-fw-card__inner { border-top-color: #0051ff; }
  .hp-fw-card--purple .hp-fw-card__inner { border-top-color: #8b5cf6; }
  .hp-fw-card__number {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    color: #6b7280;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  /* Asymmetric Split Grid (reused) */
  .hp-split__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
