---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
import BrandGravityHero from '../components/BrandGravityHero.astro';
import { getCollection } from 'astro:content';

// Fetch posts from content collection
const contentPosts = await getCollection('posts', ({ data }) => data.draft !== true);

const posts = contentPosts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  date: post.data.date,
  image: post.data.image,
  url: `/thinking/${post.slug}`,
  type: 'Article',
}));

// Case studies with dates for sorting
const caseStudies = [
  {
    title: "Building 17 Nurture Paths",
    description: "How lifecycle segmentation cut lead-to-value time from 47 days to 19",
    image: "/case-studies/hero-image-03.png",
    url: '/case-studies/lifecycle-archetypes',
    date: new Date('2025-01-15'),
    type: 'Case Study',
  },
  {
    title: "Developer-to-Enterprise Pipeline",
    description: "Turning GitHub stars into six-figure deals for open source AI",
    image: "/case-studies/hero-image-01.png",
    url: '/case-studies/developer-discovery',
    date: new Date('2025-01-10'),
    type: 'Case Study',
  },
  {
    title: "Propensity Scoring That Works",
    description: "How data governance made predictive models 30% more accurate",
    image: "/case-studies/hero-image-02.png",
    url: '/case-studies/propensity-scoring',
    date: new Date('2025-01-05'),
    type: 'Case Study',
  },
];

// Combine and sort by date
const allContent = [...posts, ...caseStudies]
  .sort((a, b) => b.date.getTime() - a.date.getTime());
---

<BaseLayout title="Strategnik — GTM Architecture & the Intelligence Layer for AI-Native Marketing" description="GTM architecture and the Intelligence Layer for Series B through pre-IPO B2B SaaS. Positioning, pipeline, content systems, and AI-native marketing built on the Physics of Growth™ framework.">
  <!-- Brand Gravity Hero Section -->
  <BrandGravityHero overlayOpacity={0.25}>
    <!-- Hero - First viewport -->
    <section class="min-h-screen flex items-start justify-center pt-20 md:pt-28">
      <div class="container-content text-center max-w-4xl mx-auto">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black mb-10 text-white leading-[1.1] tracking-tight" data-animate-hero>
          Build the engine.<br />Not the headcount.
        </h1>
        <p class="text-xl md:text-2xl text-gray-300 max-w-2xl mx-auto mb-12 leading-relaxed" data-animate-hero-sub>
          GTM architecture and the <a href="/intelligence-layer" class="text-white font-bold hover:text-blue-bright transition-colors">Intelligence Layer</a> for Series B through pre-IPO B2B SaaS. AI handles orchestration at machine speed. Your team focuses on strategy, judgment, and the work that actually requires a human brain.
        </p>
        <div class="flex flex-wrap justify-center gap-8" data-animate-hero-links>
          <a href="/intelligence-layer" class="px-8 py-3 bg-white text-black font-bold rounded-lg hover:bg-gray-200 transition-colors">
            The Intelligence Layer
          </a>
          <a href="mailto:nick@strategnik.com" class="px-8 py-3 border border-gray-600 text-white font-bold rounded-lg hover:border-white transition-colors">
            Start a conversation
          </a>
        </div>
      </div>
    </section>

    <!-- Spacer -->
    <div class="h-[10vh]"></div>

    <!-- Quick Proof -->
    <section class="pb-20">
      <div class="container-narrow text-center">
        <p class="text-body-lg text-white font-bold mb-6">
          20+ years in B2B SaaS — 3 companies acquired — ~100% avg pipeline growth
        </p>
        <p class="text-body text-gray-400 max-w-prose mx-auto">
          Most recently VP of Marketing and Growth at BRIA AI, where I built signal-driven growth systems that drove 120% MAU lift.
        </p>
      </div>
    </section>

    <!-- Featured Content Carousel -->
    <section class="pb-24">
      <div class="container-content">
        <p class="text-caption text-blue-bright tracking-wide mb-6 font-bold text-center">Latest</p>
        <div class="relative">
          <!-- Left Arrow -->
          <button
            id="carousel-prev"
            class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-4 z-10 w-10 h-10 bg-gray-900 border border-gray-700 rounded-full flex items-center justify-center text-white hover:bg-gray-800 hover:border-gray-600 transition-all shadow-lg hidden md:flex"
            aria-label="Previous"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </button>

          <!-- Carousel Container -->
          <div id="carousel-container" class="flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide scroll-smooth">
            {allContent.map((item) => (
              <a
                href={item.url}
                class="group flex-shrink-0 w-[320px] md:w-[380px] bg-gray-900 rounded-xl overflow-hidden border border-gray-800 hover:border-gray-700 hover:shadow-lg transition-all duration-300 snap-start"
              >
                <div class="aspect-video bg-gray-800 relative overflow-hidden">
                  {item.image ? (
                    <img
                      src={item.image}
                      alt={item.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-gray-800 to-gray-900">
                      <div class="w-12 h-12 rounded-lg bg-gray-900 border border-gray-800 flex items-center justify-center">
                        <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                        </svg>
                      </div>
                    </div>
                  )}
                  <div class="absolute top-3 left-3">
                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-900/90 text-white backdrop-blur-sm">
                      {item.type}
                    </span>
                  </div>
                </div>
                <div class="p-5">
                  <h3 class="font-semibold text-white group-hover:text-blue-bright transition-colors mb-2 line-clamp-2">{item.title}</h3>
                  <p class="text-sm text-gray-400 line-clamp-2">{item.description}</p>
                </div>
              </a>
            ))}
          </div>

          <!-- Right Arrow -->
          <button
            id="carousel-next"
            class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-4 z-10 w-10 h-10 bg-gray-900 border border-gray-700 rounded-full flex items-center justify-center text-white hover:bg-gray-800 hover:border-gray-600 transition-all shadow-lg hidden md:flex"
            aria-label="Next"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </button>
        </div>
      </div>
    </section>

    <script>
      const carousel = document.getElementById('carousel-container');
      const prevBtn = document.getElementById('carousel-prev');
      const nextBtn = document.getElementById('carousel-next');

      if (carousel && prevBtn && nextBtn) {
        const cardWidth = 380 + 24; // card width + gap

        prevBtn.addEventListener('click', () => {
          carousel.scrollBy({ left: -cardWidth, behavior: 'smooth' });
        });

        nextBtn.addEventListener('click', () => {
          carousel.scrollBy({ left: cardWidth, behavior: 'smooth' });
        });

        // Update button visibility based on scroll position
        const updateButtons = () => {
          prevBtn.style.opacity = carousel.scrollLeft <= 0 ? '0.3' : '1';
          prevBtn.style.pointerEvents = carousel.scrollLeft <= 0 ? 'none' : 'auto';

          const maxScroll = carousel.scrollWidth - carousel.clientWidth;
          nextBtn.style.opacity = carousel.scrollLeft >= maxScroll - 10 ? '0.3' : '1';
          nextBtn.style.pointerEvents = carousel.scrollLeft >= maxScroll - 10 ? 'none' : 'auto';
        };

        carousel.addEventListener('scroll', updateButtons);
        updateButtons();
      }
    </script>

    <!-- Framework Section -->
    <section class="pb-12">
      <div class="container-narrow">
        <p class="text-caption text-white tracking-wide mb-4 font-bold">Framework</p>
        <h2 class="text-display-xl font-display italic text-white font-extrabold mb-6">
          The Physics of Growth
        </h2>
        <p class="text-body-lg text-white font-bold max-w-prose">
          Growth isn't art or science — it's engineering. A framework built on physics principles to diagnose what's actually happening in your growth system.
        </p>
      </div>
    </section>

    <!-- Concepts -->
    <section class="pb-20">
      <div class="container-narrow">
        <div class="space-y-16 md:space-y-20">
          <div class="max-w-lg">
            <p class="text-white text-small mb-2 font-bold">01</p>
            <h3 class="text-display font-display italic text-white font-extrabold mb-4">Momentum</h3>
            <p class="text-body-lg text-white font-bold">
              Why some investments compound while others dissipate
            </p>
          </div>

          <div class="max-w-lg ml-auto text-right">
            <p class="text-white text-small mb-2 font-bold">02</p>
            <h3 class="text-display font-display italic text-white font-extrabold mb-4">Friction</h3>
            <p class="text-body-lg text-white font-bold">
              The hidden force destroying your conversion rates
            </p>
          </div>

          <div class="max-w-lg">
            <p class="text-white text-small mb-2 font-bold">03</p>
            <h3 class="text-display font-display italic text-white font-extrabold mb-4">Gravity</h3>
            <p class="text-body-lg text-white font-bold">
              Market forces pulling prospects toward (or away from) you
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 md:py-24 flex items-center justify-center">
      <div class="text-center">
        <a href="/physics-of-growth" class="text-heading font-display italic text-white font-extrabold hover:text-blue-bright transition-colors">
          Explore the framework →
        </a>
      </div>
    </section>
  </BrandGravityHero>

  <!-- The Problem Section -->
  <section class="py-16 md:py-24 bg-black">
    <div class="container-narrow">
      <h2 class="text-display text-white font-bold mb-10" data-animate>Most companies gave their team AI and called it a strategy.</h2>

      <p class="text-body-lg text-gray-400 max-w-prose mb-6">
        Output went up. Pipeline didn't move. Five teams interpreting the same brief five different ways — now doing it faster. The buyer encounters five different companies. Brand dilutes. Cycles lengthen.
      </p>

      <p class="text-body-lg text-white font-bold max-w-prose mb-10">
        The question isn't how to use AI in marketing. It's what your AI actually knows about you — and whether that's enough to act on.
      </p>

      <div class="flex flex-wrap gap-6">
        <a href="/intelligence-layer" class="text-blue-bright hover:text-white transition-colors font-bold">
          The Intelligence Layer →
        </a>
        <a href="/gravity-audit" class="text-blue-bright hover:text-white transition-colors font-bold">
          Gravity Audit →
        </a>
        <a href="/services" class="text-blue-bright hover:text-white transition-colors font-bold">
          All services →
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 md:py-24 bg-black border-t border-gray-800">
    <div class="container-narrow">
      <h2 class="text-display text-white font-bold mb-12" data-animate>Frequently Asked Questions</h2>

      <div class="space-y-10">
        <div>
          <h3 class="text-body-lg text-white font-bold mb-3">What is the Intelligence Layer?</h3>
          <p class="text-body text-gray-400 max-w-prose">The Intelligence Layer is a machine-readable operating context — brand spec, ICP hierarchy, competitive framing, content architecture, distribution schema, and measurement targets — encoded so every AI tool, agent, and team member works from the same shared foundation. It is not a document or a prompt template. It is a living system that updates as the market moves and compounds over time.</p>
        </div>

        <div>
          <h3 class="text-body-lg text-white font-bold mb-3">Does the Intelligence Layer replace marketing leadership?</h3>
          <p class="text-body text-gray-400 max-w-prose">No. Leadership sets direction — the Intelligence Layer encodes that direction into a system the entire team and every AI tool operates from. Strategy stops living in one person's head and becomes shared operating context that persists, compounds, and updates as the market moves. The CMO still steers. The layer makes sure every output reflects what they decided.</p>
        </div>

        <div>
          <h3 class="text-body-lg text-white font-bold mb-3">How does the Physics of Growth™ framework work?</h3>
          <p class="text-body text-gray-400 max-w-prose">Physics of Growth™ applies physics principles to B2B growth systems. Momentum — why some investments compound while others dissipate. Friction — the hidden forces destroying conversion rates and slowing pipeline. Gravity — the organic pull that attracts prospects versus requiring outbound to chase them. Every engagement starts by diagnosing which force is working against you, then building the systems to shift it.</p>
        </div>

        <div>
          <h3 class="text-body-lg text-white font-bold mb-3">Who is this for?</h3>
          <p class="text-body text-gray-400 max-w-prose">Series B through pre-IPO B2B SaaS companies — typically $10M to $150M ARR — where the CEO is asking whether to hire a marketing leader or build an AI-native system, or where the team has AI tools and nothing feels different. The Intelligence Layer diagnostic is also relevant for companies about to make a significant marketing hire and wondering whether the investment would be better spent on architecture.</p>
        </div>

        <div>
          <h3 class="text-body-lg text-white font-bold mb-3">What does an engagement cost?</h3>
          <p class="text-body text-gray-400 max-w-prose">The diagnostic runs $2,500–$25,000 depending on scope. The full Intelligence Layer build sprint is $25,000–$75,000 over 30–90 days. An ongoing advisor retainer is $5,000–$15,000 per month. For context: a single CMO hire costs $350K+ fully loaded per year. The build sprint costs less than one quarter of that salary and produces a system that compounds.</p>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the Intelligence Layer?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Intelligence Layer is a machine-readable operating context — brand spec, ICP hierarchy, competitive framing, content architecture, distribution schema, and measurement targets — encoded so every AI tool, agent, and team member works from the same shared foundation. It is not a document or a prompt template. It is a living system that updates as the market moves and compounds over time."
          }
        },
        {
          "@type": "Question",
          "name": "Does the Intelligence Layer replace marketing leadership?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "No. Leadership sets direction — the Intelligence Layer encodes that direction into a system the entire team and every AI tool operates from. Strategy stops living in one person's head and becomes shared operating context that persists, compounds, and updates as the market moves. The CMO still steers. The layer makes sure every output reflects what they decided."
          }
        },
        {
          "@type": "Question",
          "name": "How does the Physics of Growth framework work?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Physics of Growth applies physics principles to B2B growth systems. Momentum — why some investments compound while others dissipate. Friction — the hidden forces destroying conversion rates and slowing pipeline. Gravity — the organic pull that attracts prospects versus requiring outbound to chase them. Every engagement starts by diagnosing which force is working against you, then building the systems to shift it."
          }
        },
        {
          "@type": "Question",
          "name": "Who is Strategnik for?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Series B through pre-IPO B2B SaaS companies — typically $10M to $150M ARR — where the CEO is asking whether to hire a marketing leader or build an AI-native system, or where the team has AI tools and nothing feels different. The Intelligence Layer diagnostic is also relevant for companies about to make a significant marketing hire and wondering whether the investment would be better spent on architecture."
          }
        },
        {
          "@type": "Question",
          "name": "What does an engagement cost?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The diagnostic runs $2,500 to $25,000 depending on scope. The full Intelligence Layer build sprint is $25,000 to $75,000 over 30 to 90 days. An ongoing advisor retainer is $5,000 to $15,000 per month. For context: a single CMO hire costs $350K+ fully loaded per year. The build sprint costs less than one quarter of that salary and produces a system that compounds."
          }
        }
      ]
    })} />
  </Fragment>

  <!-- Selected Work Section -->
  <section class="py-16 md:py-24 bg-black border-t border-gray-800">
    <div class="container-narrow">
      <p class="text-caption text-blue-bright tracking-wide mb-4 font-bold">Work</p>
      <h2 class="text-display text-white font-bold mb-8" data-animate>Selected Work</h2>

      <div class="space-y-8">
        <div class="border-b border-gray-800 pb-8">
          <h3 class="text-body-lg text-white font-bold mb-2">BRIA AI</h3>
        <p class="text-body text-gray-400">Built GTM ops from zero for visual AI platform serving EA, Disney, P&G</p>        </div>

        <div class="border-b border-gray-800 pb-8">
          <h3 class="text-body-lg text-white font-bold mb-2">Lumen Technologies</h3>
          <p class="text-body text-gray-400">26% improvement in data integrity, 30% lift in propensity scores</p>
        </div>

        <div class="border-b border-gray-800 pb-8">
          <h3 class="text-body-lg text-white font-bold mb-2">Wallarm</h3>
          <p class="text-body text-gray-400">20% increase in growth-sourced pipeline, 18% conversion rate uplift</p>
        </div>
      </div>

      <div class="mt-10">
        <a href="/experience" class="text-blue-bright hover:text-white transition-colors font-bold">
          See all experience →
        </a>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <NewsletterForm variant="default" />

  <!-- Footer CTA -->
  <section class="py-16 md:py-24 bg-black border-t border-gray-800">
    <div class="container-narrow text-center">
      <h2 class="text-display text-white font-bold mb-6" data-animate>Before you hire, build, or buy</h2>
      <p class="text-body-lg text-gray-400 max-w-prose mx-auto mb-8">
        Know what you're actually missing. A 30-minute conversation — no pitch, no deck. What's happening in your growth system and how to think about it.
      </p>
      <a href="/services" class="text-blue-bright hover:text-white transition-colors font-bold text-body-lg">
        Start a conversation
      </a>
    </div>
  </section>
</BaseLayout>
