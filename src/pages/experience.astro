    period: "2023 – 2024",
    context: "Enterprise network and edge computing infrastructure.",
    highlight: "26% improvement in data integrity across Salesforce, Marketo, and DemandBase. Developed predictive analytics model improving propensity-to-buy scores by 30%. 25% increase in engagement for banking/finance and retail sectors.",
    metrics: [
      { value: "30%", label: "Propensity Score Accuracy" },
      { value: "25%", label: "Vertical Engagement Lift" }
    ],
    outcome: null,
    video: "/videos/work-lumen.mp4",
    logo: "/logos/lumen.png"
  },
  {
    company: "Crux",
    companyDesc: "Data Engineering Platform",
    role: "Demand Gen Engine Build",
    period: "2022 – 2023",
    context: "Data engineering platform targeting technical data teams.",
    highlight: "157% increase in lead-to-value velocity through optimized CRM workflows. 25-30% reduction in average cost per MQL and SQL. 40% surge in daily website traffic within two months via rapid-deployment SEO program.",
    metrics: [
      { value: "157%", label: "Velocity Improvement" },
      { value: "40%", label: "Traffic Surge in 60 Days" }
    ],
