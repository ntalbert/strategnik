// Split into featured (first) and rest
const [featured, ...rest] = workHistory;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image="/images/og-experience.png"
>

  <!-- Hero — split layout with contained video -->
  <section class="section bg-black overflow-hidden">
    <div class="container-content">
      <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-center">
        <!-- Text -->
        <div>
          <p class="text-caption text-[#0165fc] tracking-wide mb-4 font-bold" data-kinetic data-kinetic-direction="left">Experience</p>
          <h1 class="text-display-lg text-white font-extrabold mb-6" data-kinetic-up>
            The pattern: I build the system that sees what dashboards miss
          </h1>
          <p class="text-body-lg text-gray-300" data-kinetic data-kinetic-direction="right">
            Three acquisitions. Same story each time — I get brought in when the growth motion breaks, build the infrastructure that makes the real dynamics visible, and leave it compounding.
          </p>
        </div>
        <!-- Video — contained at a size where it's sharp -->
        <div class="rounded-2xl overflow-hidden aspect-video">
          <video
            class="w-full h-full object-cover lazy-video"
            muted
            loop
            playsinline
            preload="none"
            data-src="/videos/flora.mp4"
          >
          </video>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats strip — bolder treatment -->
  <section class="bg-[#060a12] border-y border-gray-800 overflow-hidden">
    <div class="container-content py-12 md:py-16">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
        <div class="text-center md:text-left" data-animate>
          <p class="text-4xl md:text-5xl text-white font-extrabold font-display tracking-tight">25+</p>
          <p class="text-small text-[#0165fc] font-bold mt-2">Years in Tech</p>
        </div>
        <div class="text-center md:text-left" data-animate data-animate-delay="0.1">
          <p class="text-4xl md:text-5xl text-white font-extrabold font-display tracking-tight">3</p>
          <p class="text-small text-[#0165fc] font-bold mt-2">Acquisitions</p>
        </div>
        <div class="text-center md:text-left" data-animate data-animate-delay="0.2">
          <p class="text-4xl md:text-5xl text-white font-extrabold font-display tracking-tight">~100%</p>
          <p class="text-small text-[#0165fc] font-bold mt-2">Avg Pipeline Growth</p>
        </div>
        <div class="text-center md:text-left" data-animate data-animate-delay="0.3">
          <p class="text-4xl md:text-5xl text-white font-extrabold font-display tracking-tight">~32%</p>
          <p class="text-small text-[#0165fc] font-bold mt-2">Avg CAC Reduction</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Role (BRIA) — large format -->
  <section class="section overflow-hidden">
    <div class="container-content">
      <p class="section-label" data-kinetic data-kinetic-direction="left">Most Recent</p>

      <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">
        <!-- Video — large -->
        <div class="rounded-2xl overflow-hidden aspect-video" data-animate>
          <video
            class="w-full h-full object-cover lazy-video"
            muted
            loop
            playsinline
            preload="none"
            data-src={featured.video}
          >
          </video>
        </div>

        <!-- Content -->
        <div>
          <div class="flex items-center gap-3 mb-4" data-kinetic data-kinetic-direction="left">
            <img src={featured.logo} alt={`${featured.company} logo`} class="h-8 w-auto" />
            <div>
              <h2 class="text-display text-white font-extrabold">{featured.company}</h2>
              <p class="text-small text-gray-400 italic">{featured.companyDesc}</p>
            </div>
          </div>

          <p class="text-body-lg text-[#0165fc] font-bold mb-4" data-kinetic-up>
            {featured.role} &middot; {featured.period}
          </p>

          <p class="text-body text-gray-300 mb-6" data-animate>
            {featured.context}
          </p>

          <p class="text-body text-gray-400 mb-8" data-animate data-animate-delay="0.1">
            {featured.highlight}
          </p>

          <!-- Pulled metrics -->
          <div class="flex gap-8" data-animate data-animate-delay="0.2">
            {featured.metrics.map((m) => (
              <div>
                <p class="text-2xl md:text-3xl text-white font-extrabold font-display">{m.value}</p>
                <p class="text-xs text-gray-500 uppercase tracking-wide mt-1">{m.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Work History — alternating layout with visual variety -->
  <section class="border-t border-gray-800 overflow-hidden">
    <div class="container-content">
      <div class="pt-20 md:pt-28 pb-4">
        <p class="section-label" data-kinetic data-kinetic-direction="left">Selected Work</p>
        <h2 class="text-display mb-4" data-kinetic-up>Every engagement follows the same arc: diagnose, build, compound</h2>
      </div>

      {rest.map((work, index) => (
        <div class={`py-12 md:py-16 border-b border-gray-800 last:border-0`}>
          <div class={`grid md:grid-cols-[1fr_1fr] gap-8 md:gap-14 items-center ${index % 2 === 1 ? 'md:[direction:rtl]' : ''}`}>
            <!-- Video -->
            <div class={`rounded-2xl overflow-hidden aspect-video ${index % 2 === 1 ? 'md:[direction:ltr]' : ''}`} data-animate>
              <video
                class="w-full h-full object-cover lazy-video"
                muted
                loop
                playsinline
                preload="none"
                data-src={work.video}
              >
              </video>
            </div>

            <!-- Content -->
            <div class={index % 2 === 1 ? 'md:[direction:ltr]' : ''}>
              <div class="flex items-center gap-3 mb-3" data-kinetic data-kinetic-direction={index % 2 === 0 ? 'left' : 'right'}>
                <img src={work.logo} alt={`${work.company} logo`} class="h-6 w-auto" />
                <h3 class="text-heading text-white font-bold">
                  {work.company}
                  <span class="text-gray-500 font-normal italic ml-2">{work.companyDesc}</span>
                </h3>
                {work.outcome && (
                  <span class="ml-auto bg-[#0165fc]/10 text-[#0165fc] text-xs font-bold px-3 py-1 rounded-full border border-[#0165fc]/20 whitespace-nowrap">
                    {work.outcome}
                  </span>
                )}
              </div>

              <p class="text-small text-[#0165fc] font-bold mb-4">
                {work.role} &middot; {work.period}
              </p>

              <p class="text-body text-gray-400 mb-6" data-animate>
                {work.highlight}
              </p>

              <!-- Pulled metrics -->
              <div class="flex gap-6" data-animate data-animate-delay="0.1">
                {work.metrics.map((m) => (
                  <div class="border-l-2 border-[#0165fc]/30 pl-4">
                    <p class="text-xl md:text-2xl text-white font-extrabold font-display">{m.value}</p>
                    <p class="text-xs text-gray-500 uppercase tracking-wide mt-0.5">{m.label}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Earlier Work — with more visual weight -->
  <section class="section bg-[#060a12] overflow-hidden">
    <div class="container-content">
      <p class="text-caption text-[#0165fc] tracking-wide mb-6 font-bold" data-kinetic data-kinetic-direction="left">Earlier Career</p>
      <h2 class="text-display text-white font-extrabold mb-12" data-kinetic-up>Agency, Academia & Brand Strategy</h2>

      <div class="grid md:grid-cols-2 gap-10 md:gap-16">
        <!-- Agency -->
        <div class="border border-gray-800 rounded-2xl p-8 md:p-10" data-parallax data-speed="0.15" data-direction="up">
          <h3 class="text-heading text-white font-bold mb-5" data-kinetic data-kinetic-direction="left">Agency Leadership</h3>
          <p class="text-body text-gray-300 mb-4" data-animate>
            Account Strategy Director across top agencies including Goodby & Silverstein, Carat SF, and David/Goliath. Managed eight-figure media budgets and oversaw teams for 45+ clients.
          </p>
          <p class="text-body text-gray-300 mb-6" data-animate data-animate-delay="0.1">
            Enterprise clients included Bellagio Hotel and Casino, Discovery Channel, Yahoo!, Conde Nast, Kodak, EA, Adobe, and Cadbury-Schweppes.
          </p>
          <div class="border-t border-gray-700 pt-4">
            <p class="text-small text-[#0165fc] font-bold">Nominated for Ad Age's "Top People to Watch Under 30"</p>
          </div>
        </div>

        <!-- Academia -->
        <div class="border border-gray-800 rounded-2xl p-8 md:p-10" data-parallax data-speed="0.25" data-direction="up">
          <h3 class="text-heading text-white font-bold mb-5" data-kinetic data-kinetic-direction="right">Academia & Brand Consulting</h3>
          <p class="text-body text-gray-300 mb-4" data-animate>
            10 years as Adjunct Professor of Digital Growth Strategy at Academy of Art University. Developed curriculum bridging technical infrastructure, data strategy, and creative execution.
          </p>
          <p class="text-body text-gray-300 mb-6" data-animate data-animate-delay="0.1">
            Senior Brand Strategist at Tattoo Brand Consulting — research contributed to greenlight of Travel Channel's <em>Bizarre Foods</em> and <em>Anthony Bourdain: No Reservations</em>.
          </p>
          <div class="border-t border-gray-700 pt-4">
            <p class="text-small text-[#0165fc] font-bold">University of Chicago Executive Program in Behavioral Economics</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Case Studies callout -->
  <section class="section border-t border-gray-800 overflow-hidden">
    <div class="container-content text-center">
      <p class="text-caption text-[#0165fc] tracking-wide mb-6 font-bold">Go Deeper</p>
      <h2 class="text-display text-white font-extrabold mb-4" data-scroll-scale data-scale-start="0.9" data-scale-end="1">
        Want to see how these systems actually work?
      </h2>
      <p class="text-body-lg text-gray-300 mb-10 max-w-prose mx-auto" data-kinetic-up>
        Six detailed case studies — situation, insight, system architecture, and measured outcome.
      </p>
      <div class="flex flex-wrap gap-8 justify-center">
        <a href="/case-studies" class="inline-flex items-center gap-2 bg-[#0165fc] text-white font-bold px-6 py-3 rounded-lg hover:bg-[#0150cc] transition-colors text-lg">
          Read the case studies &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section border-t border-gray-800 bg-black overflow-hidden">
    <div class="container-content text-center">
      <h2 class="text-display text-white font-extrabold mb-4" data-scroll-scale data-scale-start="0.9" data-scale-end="1">Want the full story?</h2>
      <p class="text-body-lg text-gray-300 mb-8 max-w-prose mx-auto" data-kinetic-up>
        The best way to understand how I work is to have a conversation.
        No pitch, just discussion.
      </p>
      <div class="flex flex-wrap gap-8 justify-center">
        <a href="mailto:nick@strategnik.com" class="text-white font-bold hover:text-[#0165fc] transition-colors text-lg" data-kinetic data-kinetic-direction="left">
          Get in touch &rarr;
        </a>
        <a href="/about" class="text-[#0165fc] font-bold hover:text-white transition-colors text-lg" data-kinetic data-kinetic-direction="right">
          Read more about me &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Lazy load videos script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const lazyVideos = document.querySelectorAll('.lazy-video');

      const videoObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const video = entry.target as HTMLVideoElement;
            const src = video.dataset.src;

            if (src && !video.querySelector('source')) {
              const source = document.createElement('source');
              source.src = src;
              source.type = 'video/mp4';
              video.appendChild(source);
              video.load();
              video.play().catch(() => {});
            }

            videoObserver.unobserve(video);
          }
        });
      }, {
        rootMargin: '100px',
        threshold: 0.1
      });

      lazyVideos.forEach(video => videoObserver.observe(video));
    });
  </script>
</BaseLayout>
