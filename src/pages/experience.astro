  },
  {
    company: "Adapt.tv",
    companyDesc: "Video Advertising DSP",
    role: "Associate VP, Product",
    period: "2014 – 2015",
    context: "Video advertising platform and DSP.",
    highlight: "Led integration of Convertro multi-touch attribution data into AOL One Platform. Owned end-to-end methodology for ingesting, normalizing, and activating attribution signals across display and video at enterprise scale.",
    metrics: [
      { value: "MTA", label: "Attribution Integration" }
