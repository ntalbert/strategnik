    video: "/videos/work-sizmek.mp4",
    logo: "/logos/crux.png"
  },
  {
    company: "OnFrontiers",
    companyDesc: "Expert Network Marketplace",
    role: "Two-Sided Marketplace Growth",
    period: "2021 – 2022",
    context: "Expert network marketplace connecting enterprise buyers with domain experts.",
    highlight: "Built simultaneous demand-side (enterprise buyers) and supply-side (expert network) audiences. 30% reduction in Customer Acquisition Cost through automation and attribution. Delivered 100+ new website pages establishing organic discovery infrastructure.",
    metrics: [
      { value: "30%", label: "CAC Reduction" },
      { value: "100+", label: "SEO Pages Deployed" }
    ],
    outcome: null,
    video: "/videos/work-onfrontiers.mp4",
    logo: "/logos/onfrontiers.png"
  },
  {
