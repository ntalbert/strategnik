{
  "headers": [
    {
      "source": "/case-studies/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/GTMengineoption1",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        },
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    },
    {
      "source": "/GTMengineoption2",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        },
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/thinking/field-unification",
      "destination": "/thinking/ai-collapsing-gtm-walls",
      "permanent": true
    },
    {
      "source": "/writing",
      "destination": "/thinking",
      "permanent": true
    },
    {
      "source": "/writing/:slug*",
      "destination": "/thinking/:slug*",
      "permanent": true
    },
    {
      "source": "/work",
      "destination": "/experience",
      "permanent": true
    },
    {
      "source": "/physics-of-marketing",
      "destination": "/physics-of-growth",
      "permanent": true
    },
    {
      "source": "/physics-of-marketing/:slug*",
      "destination": "/physics-of-growth/:slug*",
      "permanent": true
    },
    {
      "source": "/thinking/scaffolding-always-comes-down",
      "destination": "/thinking/why-ai-made-marketing-faster-not-better",
      "permanent": true
    },
    {
      "source": "/gravity-audit",
      "destination": "/digital-context-audit",
      "permanent": true
    },
    {
      "source": "/physics-of-growth/gravity-field",
      "destination": "/physics-of-growth/context-field",
      "permanent": true
    }
  ]
}
